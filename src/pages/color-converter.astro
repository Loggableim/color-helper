---
import BaseLayout from '../layouts/BaseLayout.astro';
import MonetizationSlot from '../components/MonetizationSlot.astro';
import ToolLayout from '../components/ToolLayout.astro';
import FAQ from '../components/FAQ.astro';
import ColorConverter from '../components/ColorConverter.tsx';

const title = 'Color Converter';
const description = 'Convert between HEX, RGB, RGBA, HSL, HSLA, and named CSS colors in one place. Automatic format detection.';
const canonical = 'https://color-helper.com/color-converter/';
const breadcrumbs = [{ label: 'Color Converter' }];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": title,
  "description": description,
  "url": canonical,
  "applicationCategory": "BrowserApplication",
  "operatingSystem": "All"
};
---

<BaseLayout {title} {description} {canonical} {breadcrumbs}>
  <ToolLayout {title} {description} {breadcrumbs}>
    <div class="tool-wrapper">
      <div id="color-converter-root">
        <ColorConverter client:load />

        <div class="internal-links">
          <h3>Detailed Converters</h3>
          <p>Need more control or step-by-step conversion? Use our dedicated tools:</p>
          <ul>
            <li><a href="/hex-to-rgb/">HEX to RGB Converter</a> — Convert hex color codes to RGB values</li>
            <li><a href="/rgb-to-hex/">RGB to HEX Converter</a> — Convert RGB values to hex color codes</li>
          </ul>
        </div>
      </div>
    </div>

    {{/* Ad: Tool-Bottom — zwischen Tool-UI und SEO-Text */}}
    <MonetizationSlot position="tool-bottom" adFormat="horizontal" />

    <section class="seo-content">
      <h2>What Is a Color Converter?</h2>
      <p>A color converter is a tool that transforms color values between different color models and formats — most commonly HEX, RGB, and HSL. Each format describes the same color but uses a different notation. HEX codes are compact six-character strings preceded by a hash (#RRGGBB) and are the standard in web development. RGB (Red, Green, Blue) represents colors with three decimal numbers from 0 to 255 and is the native language of digital screens. HSL (Hue, Saturation, Lightness) uses a cylindrical coordinate system that aligns more closely with how humans perceive and describe colors.</p>
      <p>Our universal color converter automatically detects which format you enter — whether it's a hex code like <code>#ff6600</code>, an RGB value like <code>rgb(255, 102, 0)</code> or <code>255, 102, 0</code>, or an HSL value like <code>hsl(30, 100%, 50%)</code> or <code>30, 100%, 50</code>. It instantly converts your input into all three formats, displays a live color preview, and even generates a ready-to-use CSS variable definition. This makes it the perfect tool for designers, front-end developers, and anyone working with colors on the web.</p>
      <p>Understanding how to convert between color formats is essential for building consistent color systems, matching brand guidelines, or troubleshooting CSS color issues. Bookmark this converter hub for quick access whenever you need to switch between HEX, RGB, and HSL.</p>
    </section>

    {{/* Ad: In-Content — nach SEO-Text, vor Related-Tools */}}
    <MonetizationSlot position="in-content" adFormat="horizontal" />

    <section class="related-tools">
      <h2>Related Tools</h2>
      <ul>
        <li><a href="/hex-to-rgb/">HEX to RGB Converter</a> — Convert hex color codes to RGB values</li>
        <li><a href="/rgb-to-hex/">RGB to HEX Converter</a> — Convert RGB values to hex color codes</li>
        <li><a href="/color-picker/">Color Picker</a> — Pick and save colors interactively</li>
      </ul>
    </section>

    <FAQ
      items={[
        {
          question: 'What is the difference between HEX, RGB, and HSL?',
          answer: 'HEX is a hexadecimal representation of color in the format #RRGGBB, widely used in HTML and CSS. RGB uses three decimal numbers (0–255) to represent red, green, and blue light intensities. HSL uses hue (0–360°), saturation (0–100%), and lightness (0–100%) — a more intuitive model that separates the color itself from its intensity and brightness.'
        },
        {
          question: 'How does the auto-detection work?',
          answer: 'The converter analyzes your input using regular expressions. If the input starts with # and contains valid hex digits, it is treated as HEX. If it contains rgb( or three comma-separated numbers between 0 and 255, it is treated as RGB. If it contains hsl( or a combination of hue (0–360), saturation (0–100%), and lightness (0–100%), it is treated as HSL. The detection updates in real time as you type.'
        },
        {
          question: 'Can I use the CSS variable output directly in my projects?',
          answer: 'Yes! The CSS Variable snippet is generated as a custom property definition like --color-primary: #ff6600; or --color-primary: rgb(255, 102, 0);. You can copy it directly into your CSS or component style block. This is especially useful when building design systems or theming with CSS custom properties.'
        },
        {
          question: 'What input formats do you support for RGB and HSL?',
          answer: 'For RGB, you can enter the functional notation rgb(255, 102, 0) or simply three comma-separated numbers 255, 102, 0. For HSL, you can use hsl(30, 100%, 50%) or the shorthand 30, 100%, 50. Both formats are automatically detected and converted to all other color representations.'
        },
        {
          question: 'Is there a difference between short (3-digit) and long (6-digit) hex codes?',
          answer: 'A 3-digit hex code like #F3A is a shorthand for the full 6-digit code #FF33AA — each digit is doubled. Both formats are fully supported. Our converter expands short codes automatically, so you can enter any valid hex format and get accurate conversions to RGB, HSL, and CSS variables.'
        }
      ]}
    />
  </ToolLayout>

  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
</BaseLayout>

<style is:global>
  .tool-wrapper {
    margin-bottom: 1.5rem;
  }

  /* ---- Internal Links ---- */
  .internal-links {
    max-width: 540px;
    margin: 2rem auto 0;
    padding: 1.25rem;
    background: var(--color-bg-alt, #f8fafc);
    border: 1px solid var(--color-border, #e2e8f0);
    border-radius: 12px;
  }

  .internal-links h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-primary, #1e293b);
  }

  .internal-links p {
    margin: 0 0 0.75rem 0;
    font-size: 0.875rem;
    color: var(--color-text-secondary, #64748b);
  }

  .internal-links ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .internal-links li {
    padding: 0.375rem 0;
    font-size: 0.875rem;
  }

  .internal-links a {
    color: #6366f1;
    text-decoration: none;
    font-weight: 600;
  }

  .internal-links a:hover {
    text-decoration: underline;
  }

  /* ---- SEO Content ---- */
  .seo-content {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 0;
  }

  .seo-content h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }

  .seo-content p {
    margin-bottom: 1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    font-size: 1.05rem;
  }

  .seo-content code {
    font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;
    font-size: 0.9em;
    background: var(--color-bg-alt, #f1f5f9);
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
  }

  /* ---- Related Tools ---- */
  .related-tools {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 0;
  }
  .related-tools h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }
  .related-tools ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .related-tools li {
    padding: 0.375rem 0;
    line-height: 1.6;
    color: var(--color-text-secondary);
    font-size: 1.05rem;
  }
  .related-tools a {
    color: #6366f1;
    text-decoration: none;
    font-weight: 600;
  }
  .related-tools a:hover {
    text-decoration: underline;
  }
</style>
