---
import BaseLayout from '../layouts/BaseLayout.astro';
import MonetizationSlot from '../components/MonetizationSlot.astro';
import ToolLayout from '../components/ToolLayout.astro';
import PaletteGallery from '../components/PaletteGallery';

const title = 'Color Palette Gallery — Curated Palettes for Designers & Developers';
const description = 'Browse 15+ hand-picked color palettes organized by category: Tech, Nature, Food, Fashion, Art, and more. Copy hex codes or export each palette as CSS Variables, SCSS, Tailwind Config, JSON Design Tokens, or Figma Variables with one click.';
const canonical = 'https://color-helper.com/gallery/';
const breadcrumbs = [{ label: 'Gallery' }];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": title,
  "description": description,
  "url": canonical,
  "applicationCategory": "BrowserApplication",
  "operatingSystem": "All"
};
---

<BaseLayout {title} {description} {canonical} {breadcrumbs}>
  <ToolLayout {title} {description} {breadcrumbs}>
    <div class="tool-wrapper">
      <PaletteGallery client:load />
    </div>

    <!-- Ad: Tool-Bottom — zwischen Tool-UI und SEO-Text -->
    <MonetizationSlot position="tool-bottom" adFormat="horizontal" />

    <section class="seo-content">
      <h2>Inspiration for Your Next Color Palette</h2>
      <p>Browse our curated collection of beautiful color palettes organized by mood and category. Each palette includes five hand-picked colors with hex codes. Click any swatch to copy, export the full palette to your preferred format, or open it in the Palette Preview system to see how it looks on real UI components.</p>
    </section>
  </ToolLayout>

  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
</BaseLayout>

<style is:global>
  .tool-wrapper { margin-bottom: 1.5rem; }
  .seo-content { max-width: 720px; margin: 0 auto; padding: 2rem 0; }
  .seo-content h2 { font-size: 1.5rem; margin-bottom: 1rem; color: var(--color-text-primary); }
  .seo-content p { margin-bottom: 1rem; line-height: 1.7; color: var(--color-text-secondary); font-size: 1.05rem; }
</style>
