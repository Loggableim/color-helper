---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Contact';
const description = 'Get in touch with the Color Helper team. Send us your suggestions, bug reports, feature requests, or accessibility feedback. We read every message.';
const canonical = 'https://color-helper.com/contact/';
---
<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
>
  <div class="content-page">
    <div class="container">
      <div class="content-wrapper">
        <h1>Contact Color Helper</h1>

        <p>
          We'd love to hear from you. Whether you have a feature idea, spotted a bug, want to suggest a new
          color tool, or have feedback on accessibility — every message helps us make Color Helper better for
          designers and developers.
        </p>

        <h2>What to contact us about</h2>
        <p>
          We especially welcome feedback on: missing color tools that should be on the site, contrast checker
          edge cases, WCAG 2.2 support, new CSS color formats (oklch, color-mix, lab), color blindness
          simulation accuracy, palette algorithm suggestions, and any tool that feels slow or confusing.
          We also accept reports of broken links, layout issues on mobile devices, and accessibility barriers
          (screen reader problems, keyboard navigation, focus visibility).
        </p>

        <h2>Email</h2>
        <p>
          The fastest way to reach us is email. We typically respond within 1-3 days, though during launch
          periods it may take a bit longer. Bug reports should include the browser, operating system, and
          steps to reproduce the issue. Screenshots are always appreciated.
        </p>

        <div class="contact-card">
          <div class="contact-card-icon">✉</div>
          <div class="contact-card-content">
            <strong>Email</strong>
            <a href="mailto:hello@color-helper.com">hello@color-helper.com</a>
          </div>
        </div>

        <h2>Response time expectations</h2>
        <p>
          Color Helper is an independent, free, ad-supported tool — not a customer service operation. We read
          every email and try to respond to actionable bug reports and feature requests within a few days.
          Questions that require longer investigation (CSS Color Module Level 5 spec questions, accessibility
          compliance for specific industries) may take a week or two. If you have a tight deadline, please
          say so in the subject line and we'll prioritize accordingly.
        </p>

        <h2>What we can't help with</h2>
        <p>
          Color Helper doesn't offer paid consulting, custom tool development, or 1-on-1 training. If you need
          a custom color tool for your product, we recommend hiring a freelance developer or designer. For
          in-depth accessibility audits of your own site, consult a WCAG specialist — the W3C maintains a list
          of certified accessibility professionals on their website.
        </p>

        <h2>Privacy of your messages</h2>
        <p>
          Your email and any attachments are used only to respond to your inquiry. We don't add you to
          marketing lists, share your email with third parties, or use it for anything other than answering
          your message. If you'd like us to delete your email from our inbox after we've responded, just say
          so in your message.
        </p>

        <p class="last-updated">
          Last updated: <time datetime="2026-06-19">June 19, 2026</time>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .content-page { padding: 2rem 0; }
  .content-wrapper { max-width: 720px; margin: 0 auto; }
  h1 { font-size: 2rem; margin-bottom: 1.5rem; color: var(--color-text-primary); }
  h2 { margin-top: 2.5rem; margin-bottom: 1rem; font-size: 1.5rem; color: var(--color-text-primary); }
  p { margin-bottom: 1.25rem; line-height: 1.7; color: var(--color-text-secondary); font-size: 1.05rem; }
  a { color: var(--color-accent, #3b82f6); text-decoration: underline; }
  .contact-card {
    margin-top: 1.5rem; padding: 1.5rem;
    background: var(--color-surface, #1e293b);
    border: 1px solid var(--color-border, #334155);
    border-radius: 12px;
    display: flex; align-items: center; gap: 1rem;
  }
  .contact-card-icon {
    font-size: 2rem; width: 48px; height: 48px;
    display: flex; align-items: center; justify-content: center;
    background: var(--color-accent-muted, rgba(59, 130, 246, 0.1));
    border-radius: 10px;
  }
  .contact-card-content strong {
    display: block; margin-bottom: 0.25rem; color: var(--color-text-primary);
  }
  .contact-card-content a { color: var(--color-accent, #3b82f6); text-decoration: none; font-weight: 500; }
  .contact-card-content a:hover { text-decoration: underline; }
  .last-updated {
    margin-top: 3rem; font-size: 0.9rem;
    color: var(--color-text-tertiary); font-style: italic;
  }
</style>
