---
import BaseLayout from '../layouts/BaseLayout.astro';
import MonetizationSlot from '../components/MonetizationSlot.astro';
import ToolLayout from '../components/ToolLayout.astro';
import FAQ from '../components/FAQ.astro';

const title = 'RGBA Converter';
const description = 'Convert any HEX or RGB color to RGBA with a live opacity slider. Preview your color and copy the CSS RGBA value instantly.';
const canonical = 'https://color-helper.com/rgba-converter/';
const breadcrumbs = [{ label: 'RGBA Converter' }];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": title,
  "description": description,
  "url": canonical,
  "applicationCategory": "BrowserApplication",
  "operatingSystem": "All"
};
---

<BaseLayout {title} {description} {canonical} {breadcrumbs}>
  <ToolLayout title="RGBA Converter" {description} {breadcrumbs}>
    <div class="tool-wrapper">
      <div id="rgba-root">
        <div class="converter-card">
          <h2 class="converter-subtitle">RGBA Converter with Opacity</h2>
          <p class="converter-desc">Enter a HEX or RGB color, adjust the opacity, and get a ready-to-use RGBA value.</p>

          <!-- HEX Input -->
          <div class="input-group">
            <label for="hex-input" class="input-label">HEX color</label>
            <input
              id="hex-input"
              type="text"
              class="color-input"
              placeholder="#ff6600"
              spellcheck="false"
              autocomplete="off"
            />
          </div>

          <!-- RGB Inputs -->
          <div class="input-group">
            <label class="input-label">RGB values</label>
            <div class="rgb-row">
              <input id="r-input" type="number" class="rgb-input" min="0" max="255" placeholder="R" value="255" />
              <input id="g-input" type="number" class="rgb-input" min="0" max="255" placeholder="G" value="102" />
              <input id="b-input" type="number" class="rgb-input" min="0" max="255" placeholder="B" value="0" />
            </div>
          </div>

          <!-- Opacity Slider -->
          <div class="input-group">
            <div class="opacity-header">
              <label class="input-label">Opacity</label>
              <span id="opacity-value" class="opacity-value">100%</span>
            </div>
            <input
              id="opacity-slider"
              type="range"
              class="opacity-slider"
              min="0"
              max="100"
              value="100"
            />
          </div>

          <!-- Live Preview -->
          <div id="preview-row" class="preview-row">
            <div class="preview-stack">
              <div id="color-preview-solid" class="color-preview" style="background-color: #ff6600;"></div>
              <div id="color-preview-alpha" class="color-preview" style="background-color: rgba(255,102,0,1);"></div>
            </div>
            <div class="preview-info">
              <div class="preview-label">Solid (top) vs RGBA (bottom)</div>
              <div id="preview-hex" class="preview-hex">#ff6600</div>
            </div>
          </div>

          <!-- Output -->
          <div id="results" class="results-card">
            <div class="result-label">RGBA CSS</div>
            <div class="result-row">
              <code id="result-rgba" class="result-value">rgba(255, 102, 0, 1)</code>
              <button class="copy-btn" data-copy="result-rgba" title="Copy RGBA">📋</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    {{/* Ad: Tool-Bottom — zwischen Tool-UI und SEO-Text */}}
    <MonetizationSlot position="tool-bottom" adFormat="horizontal" />

    <section class="seo-content">
      <h2>What Is an RGBA Converter?</h2>
      <p>An RGBA converter takes a base color — in HEX or RGB format — and lets you attach an alpha (opacity) channel to produce a CSS RGBA value. RGBA stands for Red, Green, Blue, Alpha. The first three components define the color the same way as RGB, while the alpha value (a number between 0 and 1) controls transparency: 0 is fully transparent, 1 is fully opaque.</p>
      <p>This tool gives you two ways to specify the base color. You can type a HEX code like <code>#ff6600</code>, or you can use the three RGB number inputs to dial in exact red, green, and blue values. Both inputs stay in sync — change one and the other updates automatically. The opacity slider lets you scrub from 0% to 100% with live preview updates. Two swatches show the solid color (above) and the RGBA version over a checkerboard-like background (below) so you can see the transparency effect clearly.</p>
      <p>RGBA is essential for modern web design. Use it for semi-transparent overlays, subtle shadows, glassmorphism effects, or to make text readable over background images. Instead of guessing the opacity and writing the syntax by hand, this converter gives you the exact CSS <code>rgba()</code> value you can paste straight into your stylesheet.</p>
    </section>

    {{/* Ad: In-Content — nach SEO-Text, vor Related-Tools */}}
    <MonetizationSlot position="in-content" adFormat="horizontal" />

    <section class="related-tools">
      <h2>Related Tools</h2>
      <ul>
        <li><a href="/css-color-converter/">CSS Color Converter</a> — Generate multiple CSS color formats at once</li>
        <li><a href="/color-converter/">Universal Color Converter</a> — Convert between HEX, RGB, and HSL</li>
        <li><a href="/contrast-checker/">Contrast Checker</a> — Ensure readable text with your RGBA colors</li>
      </ul>
    </section>

    <FAQ
      items={[
        {
          question: 'What is the difference between RGB and RGBA?',
          answer: 'RGB defines a color using three channels: red, green, and blue. RGBA adds a fourth channel — alpha — which controls the opacity of the color. Alpha is a number from 0 (completely transparent) to 1 (completely opaque). RGBA is useful when you want a color to have some transparency, for example in overlays, shadows, or layered designs.'
        },
        {
          question: 'Which input formats are supported?',
          answer: 'You can enter a HEX code (e.g., #ff6600 or #f60) into the HEX input field, or use the three separate R, G, B number inputs (each 0–255). Both inputs are linked: changing one updates the other automatically.'
        },
        {
          question: 'How does the opacity slider work?',
          answer: 'The opacity slider goes from 0 (fully transparent) to 100 (fully opaque). As you drag the slider, the alpha value in the RGBA output changes, and the bottom color preview updates in real time to show the effect of the transparency against a light checkerboard background.'
        },
        {
          question: 'Can I use the RGBA value directly in my CSS?',
          answer: 'Yes. The output is formatted as a valid CSS rgba() function — for example rgba(255, 102, 0, 0.75). Just click the copy button next to it and paste it anywhere a CSS color value is accepted: background-color, color, border-color, box-shadow, and more.'
        }
      ]} skipJsonLd
    />
  </ToolLayout>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@graph":[{"@type":"WebApplication","name":"RGBA Converter","description":"Convert any HEX or RGB color to RGBA with a live opacity slider. Preview your color and copy the CSS RGBA value instantly.","url":"https://color-helper.com/rgba-converter/","applicationCategory":"BrowserApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"USD"}},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is the difference between RGB and RGBA?","acceptedAnswer":{"@type":"Answer","text":"RGB defines a color using three channels: red, green, and blue. RGBA adds a fourth channel — alpha — which controls the opacity of the color. Alpha is a number from 0 (completely transparent) to 1 (completely opaque). RGBA is useful when you want a color to have some transparency, for example in overlays, shadows, or layered designs."}},{"@type":"Question","name":"Which input formats are supported?","acceptedAnswer":{"@type":"Answer","text":"You can enter a HEX code (e.g., #ff6600 or #f60) into the HEX input field, or use the three separate R, G, B number inputs (each 0–255). Both inputs are linked: changing one updates the other automatically."}},{"@type":"Question","name":"How does the opacity slider work?","acceptedAnswer":{"@type":"Answer","text":"The opacity slider goes from 0 (fully transparent) to 100 (fully opaque). As you drag the slider, the alpha value in the RGBA output changes, and the bottom color preview updates in real time to show the effect of the transparency against a light checkerboard background."}},{"@type":"Question","name":"Can I use the RGBA value directly in my CSS?","acceptedAnswer":{"@type":"Answer","text":"Yes. The output is formatted as a valid CSS rgba() function — for example rgba(255, 102, 0, 0.75). Just click the copy button next to it and paste it anywhere a CSS color value is accepted: background-color, color, border-color, box-shadow, and more."}}]},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"RGBA Converter","item":"https://color-helper.com/"}]}]})} />

<style is:global>
  .tool-wrapper { margin-bottom: 1.5rem; }
  .converter-card {
    max-width: 540px; margin: 0 auto;
    background: #ffffff; border: 1px solid var(--color-border, #e2e8f0);
    border-radius: 14px; padding: 1.5rem;
    box-shadow: 0 4px 6px -1px rgba(0,0,0,0.07), 0 2px 4px -2px rgba(0,0,0,0.05);
  }
  .converter-subtitle { margin: 0 0 0.25rem 0; font-size: 1.125rem; font-weight: 700; letter-spacing: -0.01em; color: var(--color-text-primary, #1e293b); }
  .converter-desc { margin: 0 0 1.25rem 0; font-size: 0.8125rem; color: var(--color-text-secondary, #64748b); }
  .input-group { margin-bottom: 1rem; }
  .input-label { display: block; font-size: 0.8125rem; font-weight: 600; margin-bottom: 0.375rem; color: var(--color-text-primary, #1e293b); }
  .color-input {
    display: block; width: 100%; padding: 0.625rem 0.875rem; font-size: 0.9375rem;
    font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;
    color: var(--color-text-primary, #1e293b); background: #ffffff;
    border: 1.5px solid var(--color-border, #e2e8f0); border-radius: 10px; outline: none;
    transition: border-color 0.2s, box-shadow 0.2s; letter-spacing: 0.02em; box-sizing: border-box;
  }
  .color-input:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.12); }
  .rgb-row { display: flex; gap: 0.5rem; }
  .rgb-input {
    flex: 1; padding: 0.625rem 0.5rem; font-size: 0.9375rem;
    font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;
    color: var(--color-text-primary, #1e293b); background: #ffffff;
    border: 1.5px solid var(--color-border, #e2e8f0); border-radius: 10px; outline: none;
    text-align: center; transition: border-color 0.2s, box-shadow 0.2s; box-sizing: border-box;
  }
  .rgb-input:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.12); }
  .opacity-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.375rem; }
  .opacity-value { font-size: 0.9375rem; font-weight: 700; color: var(--color-text-primary, #1e293b); font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace; }
  .opacity-slider {
    -webkit-appearance: none; appearance: none; width: 100%; height: 8px;
    background: linear-gradient(to right, #e2e8f0, #6366f1); border-radius: 4px;
    outline: none; cursor: pointer;
  }
  .opacity-slider::-webkit-slider-thumb {
    -webkit-appearance: none; appearance: none; width: 20px; height: 20px;
    border-radius: 50%; background: #6366f1; border: 2px solid #fff;
    box-shadow: 0 1px 4px rgba(0,0,0,0.2); cursor: pointer;
  }
  .preview-row { display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; }
  .preview-stack { display: flex; flex-direction: column; gap: 4px; }
  .color-preview { width: 64px; height: 48px; border-radius: 8px; border: 2px solid var(--color-border, #e2e8f0); transition: background-color 0.15s ease; flex-shrink: 0; }
  .preview-info { font-size: 0.8125rem; color: var(--color-text-secondary, #64748b); }
  .preview-label { font-weight: 600; margin-bottom: 0.25rem; }
  .preview-hex { font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace; font-size: 0.875rem; color: var(--color-text-primary, #1e293b); font-weight: 600; }
  .results-card { background: var(--color-bg-alt, #f8fafc); border: 1px solid var(--color-border, #e2e8f0); border-radius: 10px; padding: 0.75rem; margin-top: 0.5rem; }
  .result-label { font-size: 0.6875rem; font-weight: 600; color: var(--color-text-secondary, #64748b); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.375rem; }
  .result-row { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; }
  .result-value { font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace; font-size: 0.9375rem; font-weight: 600; color: var(--color-text-primary, #1e293b); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; background: transparent; padding: 0; }
  .copy-btn { flex-shrink: 0; width: 32px; height: 32px; display: inline-flex; align-items: center; justify-content: center; border: none; border-radius: 8px; background: transparent; cursor: pointer; font-size: 0.875rem; transition: background 0.15s, transform 0.1s; color: var(--color-text-secondary, #64748b); }
  .copy-btn:hover { background: var(--color-border, #e2e8f0); transform: scale(1.05); }
  .copy-btn.copied { color: #22c55e; background: rgba(34, 197, 94, 0.1); }
  .seo-content { max-width: 720px; margin: 0 auto; padding: 2rem 0; }
  .seo-content h2 { font-size: 1.5rem; margin-bottom: 1rem; color: var(--color-text-primary); }
  .seo-content p { margin-bottom: 1rem; line-height: 1.7; color: var(--color-text-secondary); font-size: 1.05rem; }
  .seo-content code { font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace; font-size: 0.9em; background: var(--color-bg-alt, #f1f5f9); padding: 0.125rem 0.375rem; border-radius: 4px; }
  .related-tools { max-width: 720px; margin: 0 auto; padding: 2rem 0; }
  .related-tools h2 { font-size: 1.5rem; margin-bottom: 1rem; color: var(--color-text-primary); }
  .related-tools ul { list-style: none; padding: 0; margin: 0; }
  .related-tools li { padding: 0.375rem 0; line-height: 1.6; color: var(--color-text-secondary); font-size: 1.05rem; }
  .related-tools a { color: #6366f1; text-decoration: none; font-weight: 600; }
  .related-tools a:hover { text-decoration: underline; }
  @media (max-width: 480px) {
    .converter-card { padding: 1rem; }
    .preview-row { flex-direction: column; align-items: flex-start; }
    .rgb-row { flex-direction: column; }
  }
</style>
