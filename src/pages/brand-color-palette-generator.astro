---
import BaseLayout from '../layouts/BaseLayout.astro';
import MonetizationSlot from '../components/MonetizationSlot.astro';
import ToolLayout from '../components/ToolLayout.astro';
import FAQ from '../components/FAQ.astro';

const title = 'Brand Color Palette Generator — Create Harmonious Brand Colors';
const description = 'Generate a complete brand color palette from a single base color. Get primary, secondary, accent, background, and text colors with accessibility contrast checks.';
const canonical = 'https://color-helper.com/brand-color-palette-generator/';
const breadcrumbs = [{ label: 'Brand Color Palette Generator' }];
---

<BaseLayout {title} {description} {canonical} {breadcrumbs}>
  <ToolLayout {title} {description} {breadcrumbs}>
    <p style="margin-bottom: 1.5rem;">
      Create a harmonious brand color palette in seconds. Pick a base color and we will generate
      <strong> primary</strong>, <strong>secondary</strong>, <strong>accent</strong>,
      <strong>background</strong>, and <strong>text</strong> colors.
    </p>

    <!-- Tool UI -->
    <section id="brand-palette-app">
      <div class="card card-elevated" style="padding: 1.5rem; margin-bottom: 2rem;">
        <div class="tool-panel-single">
          <div class="input-group" style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;">
            <label for="bp-base" style="font-weight: 600;">Base Color</label>
            <input type="color" id="bp-base" value="#3B82F6" style="width: 48px; height: 48px; border: none; padding: 0; cursor: pointer;" />
            <input type="text" id="bp-hex" value="#3B82F6" maxlength="7" placeholder="#RRGGBB" class="input" style="width: 120px; font-family: var(--font-mono);" />
          </div>
        </div>
      </div>

      <div id="bp-palette" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 0.75rem; margin-bottom: 2rem;"></div>

      <div id="bp-a11y" style="margin-bottom: 2rem;">
        <h3 style="margin-bottom: 0.75rem;">Accessibility Check</h3>
        <div id="bp-a11y-results" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 0.75rem;"></div>
      </div>

      <div id="bp-export" style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.5rem;">
        <button id="bp-copy-css" class="btn btn-primary btn-sm" type="button">Copy CSS</button>
        <button id="bp-export-json" class="btn btn-secondary btn-sm" type="button">Export JSON</button>
        <button id="bp-export-tailwind" class="btn btn-secondary btn-sm" type="button">Export Tailwind</button>
        <button id="bp-save-btn" class="btn btn-secondary btn-sm" type="button">💾 Save Palette</button>
      </div>

      <div class="card" style="padding: 1.25rem;">
        <h3 style="margin-bottom: 0.75rem;">CSS Custom Properties</h3>
        <pre id="bp-css" style="background: #0f172a; color: #e2e8f0; padding: 1rem; border-radius: 10px; font-family: var(--font-mono); font-size: 0.8125rem; overflow-x: auto; margin-bottom: 0.75rem;"></pre>
        <div style="display: flex; gap: 0.5rem;">
          <button id="bp-download" class="btn btn-secondary btn-sm" type="button">Download .css</button>
        </div>
      </div>
    </section>

    <script>
      (() => {
        'use strict';

        /* ===== URL Params ===== */
        function getParam(key) {
          const p = new URLSearchParams(window.location.search);
          return p.get(key);
        }
        function setParam(key, value) {
          const url = new URL(window.location.href);
          if (value) url.searchParams.set(key, value);
          else url.searchParams.delete(key);
          window.history.replaceState({}, '', url.toString());
        }

        /* ===== Storage Helpers ===== */
        function savePaletteToStorage(name, colors) {
          try {
            const raw = localStorage.getItem('color-helper:saved-palettes');
            const data = raw ? JSON.parse(raw) : { palettes: [], recentColors: [] };
            const palette = {
              id: Date.now().toString(36) + Math.random().toString(36).slice(2, 8),
              name: name,
              colors: colors.map(c => c.toLowerCase()),
              createdAt: new Date().toISOString(),
              updatedAt: new Date().toISOString(),
              source: 'brand',
            };
            data.palettes = [palette, ...data.palettes];
            localStorage.setItem('color-helper:saved-palettes', JSON.stringify(data));
            return true;
          } catch(e) { return false; }
        }

        function addRecentColor(hex) {
          try {
            const raw = localStorage.getItem('color-helper:saved-palettes');
            const data = raw ? JSON.parse(raw) : { palettes: [], recentColors: [] };
            const normalized = hex.toLowerCase();
            data.recentColors = [normalized, ...data.recentColors.filter(c => c !== normalized)];
            if (data.recentColors.length > 20) data.recentColors = data.recentColors.slice(0, 20);
            localStorage.setItem('color-helper:saved-palettes', JSON.stringify(data));
          } catch(e) { /* silent */ }
        }

        const colorInput = document.getElementById('bp-base');
        const hexInput = document.getElementById('bp-hex');
        const paletteEl = document.getElementById('bp-palette');
        const a11yEl = document.getElementById('bp-a11y-results');
        const cssPre = document.getElementById('bp-css');
        const copyBtn = document.getElementById('bp-copy-css');
        const dloadBtn = document.getElementById('bp-download');
        const exportJsonBtn = document.getElementById('bp-export-json');
        const exportTailwindBtn = document.getElementById('bp-export-tailwind');
        const saveBtn = document.getElementById('bp-save-btn');

        function hex2rgb(h) {
          const c = h.replace('#','');
          if (c.length !== 6) return null;
          const n = parseInt(c, 16);
          if (isNaN(n)) return null;
          return { r: (n>>16)&255, g: (n>>8)&255, b: n&255 };
        }

        function rgb2hex(r,g,b) {
          return '#' + [r,g,b].map(v => Math.round(Math.max(0,Math.min(255,v))).toString(16).padStart(2,'0')).join('');
        }

        function lum(r,g,b) {
          const f = c => { const v=c/255; return v<=0.04045 ? v/12.92 : Math.pow((v+0.055)/1.055,2.4); };
          return 0.2126*f(r) + 0.7152*f(g) + 0.0722*f(b);
        }

        function ratio(h1, h2) {
          const c1=hex2rgb(h1), c2=hex2rgb(h2);
          if (!c1||!c2) return 0;
          const l1=lum(c1.r,c1.g,c1.b), l2=lum(c2.r,c2.g,c2.b);
          return Math.round((Math.max(l1,l2)+0.05)/(Math.min(l1,l2)+0.05)*100)/100;
        }

        function generatePalette(hex) {
          const rgb = hex2rgb(hex);
          if (!rgb) return null;
          const { r, g, b } = rgb;
          const primary = hex;
          const secondary = rgb2hex(g, b, r);
          const accent = rgb2hex(Math.min(255,r+60), Math.min(255,g+40), Math.min(255,b+100));
          const bg = rgb2hex(Math.min(255,r+200), Math.min(255,g+200), Math.min(255,b+200));
          const text = rgb2hex(Math.max(0,r-120), Math.max(0,g-120), Math.max(0,b-120));
          return { primary, secondary, accent, background: bg, text };
        }

        function render() {
          let hex = hexInput.value;
          if (!hex.startsWith('#')) hex = '#' + hex;
          // Validate
          const stripped = hex.replace('#', '');
          if (!/^[0-9a-f]{6}$/i.test(stripped)) return;

          const palette = generatePalette(hex);
          if (!palette) return;

          // Update URL param
          setParam('base', stripped);

          paletteEl.innerHTML = Object.entries(palette).map(([key, val]) =>
            `<div class="card" style="padding: 1rem; text-align: center;">
              <div style="width:100%;height:64px;border-radius:8px;background:${val};border:1px solid #e2e8f0;margin-bottom:0.5rem;"></div>
              <div style="font-size:0.75rem;font-weight:600;text-transform:capitalize;color:#64748b;">${key}</div>
              <div style="font-family:'JetBrains Mono',monospace;font-size:0.8125rem;color:#0f172a;">${val}</div>
            </div>`
          ).join('');

          const pairs = [
            { label: 'Text on Background', fg: palette.text, bg: palette.background },
            { label: 'Text on Primary', fg: palette.text, bg: palette.primary },
            { label: 'Text on Secondary', fg: palette.text, bg: palette.secondary },
          ];

          a11yEl.innerHTML = pairs.map(p => {
            const r = ratio(p.fg, p.bg);
            const aa = r >= 4.5, aaLarge = r >= 3, aaa = r >= 7;
            return `<div class="card" style="padding: 1rem;">
              <div style="font-size:0.875rem;font-weight:600;margin-bottom:0.5rem;">${p.label}</div>
              <div style="font-size:1.5rem;font-weight:700;margin-bottom:0.25rem;">${r}:1</div>
              <div style="display:flex;gap:0.375rem;flex-wrap:wrap;">
                <span class="wcag-badge ${aa?'wcag-pass':'wcag-fail'}">AA ${aa?'PASS':'FAIL'}</span>
                <span class="wcag-badge ${aaLarge?'wcag-pass':'wcag-fail'}">AA Large ${aaLarge?'PASS':'FAIL'}</span>
                <span class="wcag-badge ${aaa?'wcag-pass':'wcag-fail'}">AAA ${aaa?'PASS':'FAIL'}</span>
              </div>
            </div>`;
          }).join('');

          const cssVars = Object.entries(palette).map(([k, v]) => `  --color-${k}: ${v};`).join('\n');
          cssPre.textContent = `:root {\n${cssVars}\n}`;
        }

        function readHexFromUrl() {
          const base = getParam('base');
          if (base) {
            let hex = base.trim();
            if (!hex.startsWith('#')) hex = '#' + hex;
            const stripped = hex.replace('#', '');
            if (/^[0-9a-f]{6}$/i.test(stripped)) {
              colorInput.value = hex.toLowerCase();
              hexInput.value = hex.toLowerCase();
              render();
            }
          }
        }

        colorInput.addEventListener('input', () => {
          hexInput.value = colorInput.value;
          render();
        });
        hexInput.addEventListener('input', () => {
          if (/^#?[0-9a-f]{6}$/i.test(hexInput.value.replace('#',''))) {
            const v = hexInput.value.startsWith('#') ? hexInput.value : '#' + hexInput.value;
            colorInput.value = v;
            render();
          }
        });
        copyBtn.addEventListener('click', () => {
          navigator.clipboard.writeText(cssPre.textContent).then(() => copyBtn.textContent = 'Copied!');
          setTimeout(() => copyBtn.textContent = 'Copy CSS', 2000);
        });
        dloadBtn.addEventListener('click', () => {
          const blob = new Blob([cssPre.textContent], { type: 'text/css' });
          const a = document.createElement('a');
          a.href = URL.createObjectURL(blob);
          a.download = 'brand-palette.css';
          a.click();
          URL.revokeObjectURL(a.href);
        });

        // Export JSON
        exportJsonBtn.addEventListener('click', () => {
          const palette = generatePalette(hexInput.value.startsWith('#') ? hexInput.value : '#' + hexInput.value);
          if (!palette) return;
          const json = JSON.stringify(palette, null, 2);
          navigator.clipboard.writeText(json).then(() => {
            exportJsonBtn.textContent = '✓ JSON Copied!';
            setTimeout(() => exportJsonBtn.textContent = 'Export JSON', 2000);
          });
        });

        // Export Tailwind
        exportTailwindBtn.addEventListener('click', () => {
          const palette = generatePalette(hexInput.value.startsWith('#') ? hexInput.value : '#' + hexInput.value);
          if (!palette) return;
          const entries = Object.entries(palette).map(([k, v]) => `    '${k}': '${v}'`).join(',\n');
          const tw = `{\n  colors: {\n${entries}\n  }\n}`;
          navigator.clipboard.writeText(tw).then(() => {
            exportTailwindBtn.textContent = '✓ Tailwind Copied!';
            setTimeout(() => exportTailwindBtn.textContent = 'Export Tailwind', 2000);
          });
        });

        // Save palette
        saveBtn.addEventListener('click', () => {
          const palette = generatePalette(hexInput.value.startsWith('#') ? hexInput.value : '#' + hexInput.value);
          if (!palette) return;
          const colors = Object.values(palette);
          const ok = savePaletteToStorage('Brand Palette', colors);
          if (ok) {
            colors.forEach(c => addRecentColor(c));
            saveBtn.textContent = '✓ Saved!';
            setTimeout(() => saveBtn.textContent = '💾 Save Palette', 2000);
          }
        });

        // Read URL param on load
        readHexFromUrl();

        // Initial render if no URL param
        if (!getParam('base')) {
          render();
        }
      })();
    </script>

    <!-- SEO Content -->
    <section class="seo-content" style="max-width: 680px; margin: 3rem auto 0;">
      <h2>What Is a Brand Color Palette?</h2>
      <p>A brand color palette is a curated set of colors that defines a brand visual identity. It typically includes a primary color for the logo and main elements, a secondary color for variety, an accent color for highlights, a background color for surfaces, and a text color for readability. A cohesive palette ensures consistency across all brand touchpoints — from websites to business cards.</p>
      <h2>How to Use This Generator</h2>
      <p>Start with your core brand color. The generator automatically creates a complete five-color palette with built-in WCAG accessibility checks. Adjust the base color until all text-background combinations pass at least AA level. Copy the result as CSS custom properties for direct use in your project.</p>
      <h2>Why Accessibility Matters in Brand Colors</h2>
      <p>WCAG 2.1 requires a contrast ratio of at least 4.5:1 for normal text and 3:1 for large text (AA level). Using your palette generator with built-in checks ensures your brand is usable by everyone, including users with low vision or color vision deficiencies.</p>
    </section>
  </ToolLayout>

  <FAQ title="Frequently Asked Questions" items={[
    { question: 'What is a brand color palette generator?', answer: 'It is a tool that creates a complete set of brand colors — primary, secondary, accent, background, and text — from a single base color. It also checks accessibility contrast ratios automatically.' },
    { question: 'How many colors does a brand palette need?', answer: 'A basic brand palette works well with 4-5 colors: primary, secondary, accent, background, and text. You can extend it with additional shades and tints as needed.' },
    { question: 'What accessibility checks are performed?', answer: 'The tool checks WCAG 2.1 contrast ratios between text and background combinations, verifying AA (4.5:1) and AAA (7:1) compliance for normal and large text.' },
    { question: 'Can I export the palette?', answer: 'Yes. Click "Copy CSS" to copy CSS custom properties to your clipboard, or "Download .css" to save them as a file for your project.' },
  ]} />

  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@graph":[{"@type":"WebApplication","name":"Brand Color Palette Generator — Create Harmonious Brand Colors","description":"Generate a complete brand color palette from a single base color. Get primary, secondary, accent, background, and text colors with accessibility contrast checks.","url":"https://color-helper.com/brand-color-palette-generator/","applicationCategory":"BrowserApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"USD"}},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Brand Color Palette Generator","item":"https://color-helper.com/"}]}]})} />
</BaseLayout>

<style is:global>
  #bp-palette .card { border-radius: var(--radius-lg); }
  #bp-a11y-results .card { border-radius: var(--radius-lg); }
  #bp-palette .card:hover { box-shadow: var(--shadow-md); }
</style>
