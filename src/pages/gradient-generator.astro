---
import BaseLayout from '../layouts/BaseLayout.astro';
import MonetizationSlot from '../components/MonetizationSlot.astro';
import ToolLayout from '../components/ToolLayout.astro';
import GradientGenerator from '../components/GradientGenerator';
import FAQ from '../components/FAQ.astro';

const title = 'Gradient Generator';
const description = 'Create beautiful CSS gradients with our free online gradient generator. Generate linear and radial gradients with custom colors, multiple stops, and direction control.';
const canonical = 'https://color-helper.com/gradient-generator/';
const breadcrumbs = [{ label: 'Gradient Generator' }];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": title,
  "description": description,
  "url": canonical,
  "applicationCategory": "BrowserApplication",
  "operatingSystem": "All"
};
---

<BaseLayout {title} {description} {canonical} {breadcrumbs}>
  <ToolLayout {title} {description} {breadcrumbs}>
    <div class="tool-wrapper">
      <GradientGenerator client:load />
    </div>

    {{/* Ad: Tool-Bottom — zwischen Tool-UI und SEO-Text */}}
    <MonetizationSlot position="tool-bottom" adFormat="horizontal" />

    <section class="seo-content">
      <h2>How to Create Stunning CSS Gradients</h2>
      <p>Our gradient generator makes it easy to create beautiful gradient backgrounds for your web projects. Choose between linear or radial gradient types, pick two or more colors with position controls, and adjust the direction or angle to get the perfect look. The preview updates in real time so you can see exactly what your gradient will look like.</p>
      <p>Linear gradients transition colors along a straight line. You can control the direction by setting an angle (0–360 degrees) or using predefined directions like top-to-bottom or left-to-right. Radial gradients radiate outward from a center point, with support for ellipse and circle shapes at custom positions. Each type creates a different visual effect suitable for different design contexts.</p>
      <p>Once you're happy with your gradient, simply copy the generated CSS code and paste it into your stylesheet. The tool outputs standard CSS background-image syntax that works in all modern browsers. You can also add multiple color stops for more complex gradients, adjust the stop positions, use preset gradients, save your favorites, share via URL parameters, and preview how the gradient looks as a full-page background.</p>
    </section>

    {{/* Ad: In-Content — nach SEO-Text, vor Related-Tools */}}
    <MonetizationSlot position="in-content" adFormat="horizontal" />

    <section class="related-tools">
      <h2>Related Tools</h2>
      <ul>
        <li><a href="/color-palette-generator/">Color Palette Generator</a> — Create harmonious color schemes</li>
        <li><a href="/color-converter/">Color Converter</a> — Convert between HEX, RGB, and HSL</li>
        <li><a href="/color-picker/">Color Picker</a> — Pick and save colors interactively</li>
      </ul>
    </section>

    <FAQ
      items={[
        {
          question: 'What is a CSS gradient?',
          answer: 'A CSS gradient is a smooth transition between two or more colors that you can use as a background image in web design. Gradients are created using the CSS background-image property with functions like linear-gradient(), radial-gradient(), and conic-gradient().'
        },
        {
          question: 'What types of gradients can I create?',
          answer: 'You can create linear gradients (colors transition along a straight line) and radial gradients (colors radiate outward from a center point). Each type offers unique visual effects for different design needs.'
        },
        {
          question: 'How do I add more colors to my gradient?',
          answer: 'Click the "Add Stop" button to insert additional color stops. You can specify the position of each color stop as a percentage using the slider or number input. This allows you to create complex multi-color gradients with precise control over where each color appears.'
        },
        {
          question: 'Can I save or share my gradients?',
          answer: 'Yes! You can save gradients to your local storage with a custom name by using the Save button. You can also share gradients via URL parameters — just add ?from=COLOR1&to=COLOR2&angle=135 to the gradient generator URL. Additionally, preset gradients are available for quick inspiration.'
        },
        {
          question: 'Do all browsers support CSS gradients?',
          answer: 'Yes, CSS gradients are supported in all modern browsers including Chrome, Firefox, Safari, and Edge. The generated code uses standard CSS syntax without vendor prefixes, ensuring broad compatibility across current browser versions.'
        }
      ]} skipJsonLd
    />
  </ToolLayout>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@graph":[{"@type":"WebApplication","name":"Gradient Generator","description":"Create beautiful CSS gradients with our free online gradient generator. Generate linear and radial gradients with custom colors, multiple stops, and direction control.","url":"https://color-helper.com/gradient-generator/","applicationCategory":"BrowserApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"USD"}},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is a CSS gradient?","acceptedAnswer":{"@type":"Answer","text":"A CSS gradient is a smooth transition between two or more colors that you can use as a background image in web design. Gradients are created using the CSS background-image property with functions like linear-gradient(), radial-gradient(), and conic-gradient()."}},{"@type":"Question","name":"What types of gradients can I create?","acceptedAnswer":{"@type":"Answer","text":"You can create linear gradients (colors transition along a straight line) and radial gradients (colors radiate outward from a center point). Each type offers unique visual effects for different design needs."}},{"@type":"Question","name":"How do I add more colors to my gradient?","acceptedAnswer":{"@type":"Answer","text":"Click the \"Add Stop\" button to insert additional color stops. You can specify the position of each color stop as a percentage using the slider or number input. This allows you to create complex multi-color gradients with precise control over where each color appears."}},{"@type":"Question","name":"Can I save or share my gradients?","acceptedAnswer":{"@type":"Answer","text":"Yes! You can save gradients to your local storage with a custom name by using the Save button. You can also share gradients via URL parameters — just add ?from=COLOR1&to=COLOR2&angle=135 to the gradient generator URL. Additionally, preset gradients are available for quick inspiration."}},{"@type":"Question","name":"Do all browsers support CSS gradients?","acceptedAnswer":{"@type":"Answer","text":"Yes, CSS gradients are supported in all modern browsers including Chrome, Firefox, Safari, and Edge. The generated code uses standard CSS syntax without vendor prefixes, ensuring broad compatibility across current browser versions."}}]},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Gradient Generator","item":"https://color-helper.com/"}]}]})} />
</BaseLayout>

<style is:global>
  .tool-wrapper {
    margin-bottom: 1.5rem;
  }
  .seo-content {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 0;
  }
  .seo-content h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }
  .seo-content p {
    margin-bottom: 1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    font-size: 1.05rem;
  }

  .related-tools {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 0;
  }
  .related-tools h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }
  .related-tools ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .related-tools li {
    padding: 0.375rem 0;
    line-height: 1.6;
    color: var(--color-text-secondary);
    font-size: 1.05rem;
  }
  .related-tools a {
    color: #6366f1;
    text-decoration: none;
    font-weight: 600;
  }
  .related-tools a:hover {
    text-decoration: underline;
  }
</style>
