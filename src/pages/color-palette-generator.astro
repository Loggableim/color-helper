</BaseLayout>

<style is:global>
  .tool-wrapper {
    margin-bottom: 1.5rem;
  }
  .seo-content {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 0;
  }
  .seo-content h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }
  .seo-content p {
    margin-bottom: 1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    font-size: 1.05rem;
  }

  .related-tools {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 0;
  }
  .related-tools h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }
  .related-tools ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .related-tools li {
    padding: 0.375rem 0;
    line-height: 1.6;
    color: var(--color-text-secondary);
    font-size: 1.05rem;
  }
  .related-tools a {
    color: #6366f1;
    text-decoration: none;
    font-weight: 600;
  }
  .related-tools a:hover {
    text-decoration: underline;
  }
</style>
