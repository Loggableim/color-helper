---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolLayout from '../components/ToolLayout.astro';
import FAQ from '../components/FAQ.astro';

const title = 'Random Color Generator';
const description = 'Generate random colors with instant HEX, RGB and HSL values. Create and lock color palettes. Save your favorite color schemes locally.';
const canonical = 'https://color-helper.com/random-color-generator/';
const breadcrumbs = [{ label: 'Random Color Generator' }];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": title,
  "description": description,
  "url": canonical,
  "applicationCategory": "BrowserApplication",
  "operatingSystem": "All"
};
---

<BaseLayout {title} {description} {canonical} {breadcrumbs}>
  <ToolLayout title="Random Color Generator" {description} {breadcrumbs}>
    <div class="tool-wrapper">
      <div id="random-root">
        <div class="converter-card">
          <h2 class="converter-subtitle">Random Color Generator</h2>
          <p class="converter-desc">Generate a random color, view it in HEX/RGB/HSL, and build a palette you can lock, shuffle, and save.</p>

          <!-- Single Color -->
          <div id="single-section" class="section-block">
            <div id="single-preview" class="single-preview" style="background-color: #6366f1;">
              <div class="single-info">
                <span id="single-hex" class="single-hex">#6366f1</span>
              </div>
            </div>

            <div class="single-outputs">
              <div class="output-row">
                <span class="output-label">HEX</span>
                <code id="single-result-hex" class="output-value">#6366f1</code>
                <button class="copy-btn" data-copy="single-result-hex" title="Copy HEX">📋</button>
              </div>
              <div class="output-row">
                <span class="output-label">RGB</span>
                <code id="single-result-rgb" class="output-value">rgb(99, 102, 241)</code>
                <button class="copy-btn" data-copy="single-result-rgb" title="Copy RGB">📋</button>
              </div>
              <div class="output-row">
                <span class="output-label">HSL</span>
                <code id="single-result-hsl" class="output-value">hsl(239, 84%, 67%)</code>
                <button class="copy-btn" data-copy="single-result-hsl" title="Copy HSL">📋</button>
              </div>
            </div>

            <button id="generate-single" class="action-btn">Generate Random Color</button>
          </div>

          <!-- Palette -->
          <div class="section-divider"></div>

          <div class="section-block">
            <h3 class="section-title">Color Palette</h3>

            <!-- Color Mode Selector -->
            <div class="mode-selector">
              <label class="mode-label">Mode:</label>
              <div class="mode-buttons">
                <button class="mode-btn active" data-mode="random">Random</button>
                <button class="mode-btn" data-mode="pastel">Pastel</button>
                <button class="mode-btn" data-mode="vivid">Vivid</button>
                <button class="mode-btn" data-mode="dark">Dark</button>
                <button class="mode-btn" data-mode="neon">Neon</button>
                <button class="mode-btn" data-mode="earthy">Earthy</button>
              </div>
            </div>

            <!-- Accessible toggle -->
            <label class="accessible-toggle">
              <input type="checkbox" id="accessible-mode" />
              <span>WCAG AA on white</span>
            </label>

            <div id="palette" class="palette-grid">
              <!-- 5 colors generated by JS -->
            </div>
            <div class="palette-actions">
              <button id="generate-palette" class="action-btn">Generate New Palette</button>
              <button id="save-palette" class="action-btn action-btn-secondary">💾 Save Palette</button>
            </div>
            <div class="export-actions">
              <button id="export-css" class="action-btn action-btn-secondary">📋 Copy CSS Variables</button>
              <button id="export-json" class="action-btn action-btn-secondary">📋 Copy JSON</button>
            </div>
            <div id="save-msg" class="save-msg" style="display: none;">Palette saved to localStorage!</div>
          </div>
        </div>
      </div>
    </div>

    <section class="seo-content">
      <h2>What Is a Random Color Generator?</h2>
      <p>A random color generator creates unpredictable color values — in HEX, RGB, and HSL formats — with a single click. It is a great source of inspiration for designers, front-end developers, and artists who want to break out of their usual color habits or quickly populate a design mockup with placeholder swatches. Each generated color is accompanied by its full specification so you can copy the format you need.</p>
      <p>This tool goes a step further by including a palette mode that generates five coordinated random colors at once. Each color swatch has a lock toggle: click the lock icon to prevent that color from changing when you generate a new palette. This lets you iteratively refine a palette — keep a base color you like and reshuffle the rest until everything clicks. Once you are happy with a set, hit "Save Palette" to store it in your browser's localStorage. Saved palettes persist between sessions, so you can build a personal collection of color schemes over time.</p>
      <p>Whether you are prototyping a UI, searching for a accent color, or just having fun exploring color space, this generator gives you an endless stream of fresh colors with zero friction. All generation runs client-side — nothing is sent to any server.</p>
    </section>

    <section class="related-tools">
      <h2>Related Tools</h2>
      <ul>
        <li><a href="/color-palette-generator/">Palette Generator</a> — Generate harmonious palettes with color theory rules</li>
        <li><a href="/color-picker/">Color Picker</a> — Pick specific colors interactively</li>
        <li><a href="/color-converter/">Color Converter</a> — Convert between color formats</li>
        <li><a href="/color-mixer/">Color Mixer</a> — Mix and blend two colors together</li>
      </ul>
    </section>

    <FAQ
      items={[
        {
          question: 'Are the random colors truly random?',
          answer: 'Each color is generated using Math.random() in JavaScript, which produces a pseudo-random distribution across the full RGB color space (16.7 million possible colors). While not cryptographically random, the distribution is sufficiently uniform for design inspiration and prototyping.'
        },
        {
          question: 'How does the lock feature work?',
          answer: 'Each color swatch in the palette has a lock icon. Clicking it toggles the locked state — locked colors keep their current value when you generate a new palette, while unlocked colors are replaced with new random colors. This lets you incrementally build a palette you like.'
        },
        {
          question: 'Where are saved palettes stored?',
          answer: 'Palettes are saved to your browser\'s localStorage under the key "random-color-palettes". They persist across page reloads and browser sessions on the same device. Clearing your browser data will remove saved palettes.'
        },
        {
          question: 'Can I download or export my palette?',
          answer: 'Currently, saved palettes are stored in your browser. You can copy individual color values using the copy buttons next to each format. For more advanced palette management, use our dedicated Palette Generator tool.'
        }
      ]}
    />
  </ToolLayout>

  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
</BaseLayout>

<script>
  (function() {
    'use strict';

    function randomByte() { return Math.floor(Math.random() * 256); }
    function randomHex() {
      const r = randomByte(), g = randomByte(), b = randomByte();
      return { r, g, b, hex: rgbToHex(r, g, b) };
    }
    function rgbToHex(r, g, b) {
      const clamp = n => Math.min(255, Math.max(0, Math.round(n)));
      return '#' + [r, g, b].map(c => clamp(c).toString(16).padStart(2, '0')).join('');
    }
    function rgbToHsl(r, g, b) {
      const rr = r / 255, gg = g / 255, bb = b / 255;
      const max = Math.max(rr, gg, bb), min = Math.min(rr, gg, bb);
      const diff = max - min;
      let h = 0, s = 0, l = (max + min) / 2;
      if (diff !== 0) {
        s = l > 0.5 ? diff / (2 - max - min) : diff / (max + min);
        switch (max) {
          case rr: h = ((gg - bb) / diff + (gg < bb ? 6 : 0)) * 60; break;
          case gg: h = ((bb - rr) / diff + 2) * 60; break;
          case bb: h = ((rr - gg) / diff + 4) * 60; break;
        }
      }
      return { h: Math.round(h), s: Math.round(s * 100), l: Math.round(l * 100) };
    }

    // ===== Color Modes =====
    const COLOR_MODES = {
      random: { name: 'Random', sRange: [0, 100], lRange: [5, 95] },
      pastel: { name: 'Pastel', sRange: [20, 45], lRange: [60, 85] },
      vivid:  { name: 'Vivid',  sRange: [70, 100], lRange: [40, 60] },
      dark:   { name: 'Dark',   sRange: [0, 40],  lRange: [5, 22] },
      neon:   { name: 'Neon',   sRange: [85, 100], lRange: [50, 65] },
      earthy: { name: 'Earthy', sRange: [20, 55], lRange: [25, 45] },
    };

    let currentMode = 'random';
    let accessibleMode = false;

    function hslToRgb(h, s, l) {
      s /= 100; l /= 100;
      const c = (1 - Math.abs(2 * l - 1)) * s;
      const x = c * (1 - Math.abs((h / 60) % 2 - 1));
      const m = l - c / 2;
      let r = 0, g = 0, b = 0;
      if (h < 60) { r = c; g = x; }
      else if (h < 120) { r = x; g = c; }
      else if (h < 180) { g = c; b = x; }
      else if (h < 240) { g = x; b = c; }
      else if (h < 300) { r = x; b = c; }
      else { r = c; b = x; }
      return { r: Math.round((r + m) * 255), g: Math.round((g + m) * 255), b: Math.round((b + m) * 255) };
    }

    function randomHexWithMode(mode) {
      const config = COLOR_MODES[mode] || COLOR_MODES.random;
      const h = Math.floor(Math.random() * 360);
      const s = config.sRange[0] + Math.random() * (config.sRange[1] - config.sRange[0]);
      const l = config.lRange[0] + Math.random() * (config.lRange[1] - config.lRange[0]);
      const { r, g, b } = hslToRgb(h, s, l);
      return { r, g, b, hex: rgbToHex(r, g, b) };
    }

    // ===== WCAG Contrast Utilities =====
    function relativeLuminance(r, g, b) {
      const rs = r / 255, gs = g / 255, bs = b / 255;
      const rl = rs <= 0.03928 ? rs / 12.92 : Math.pow((rs + 0.055) / 1.055, 2.4);
      const gl = gs <= 0.03928 ? gs / 12.92 : Math.pow((gs + 0.055) / 1.055, 2.4);
      const bl = bs <= 0.03928 ? bs / 12.92 : Math.pow((bs + 0.055) / 1.055, 2.4);
      return 0.2126 * rl + 0.7152 * gl + 0.0722 * bl;
    }

    function contrastRatioOnWhite(r, g, b) {
      const l1 = relativeLuminance(r, g, b);
      return (1 + 0.05) / (l1 + 0.05);
    }

    function generateAccessibleColor(mode) {
      for (let attempt = 0; attempt < 100; attempt++) {
        const color = randomHexWithMode(mode);
        if (contrastRatioOnWhite(color.r, color.g, color.b) >= 4.5) {
          return color;
        }
      }
      // Fallback: force high lightness
      const fallback = hslToRgb(Math.floor(Math.random() * 360), 40 + Math.random() * 60, 70 + Math.random() * 20);
      return { ...fallback, hex: rgbToHex(fallback.r, fallback.g, fallback.b) };
    }

    // ===== Export Formatters (inlined from storage.ts) =====
    function formatCSSVariables(colors) {
      return colors.map((c, i) => `  --color-${i + 1}: ${c};`).join('\n');
    }

    function formatJSON(colors) {
      return JSON.stringify(colors, null, 2);
    }

    // ===== Storage Helpers (inlined from storage.ts) =====
    function addRecentColor(hex) {
      try {
        const raw = localStorage.getItem('color-helper:saved-palettes');
        const data = raw ? JSON.parse(raw) : { palettes: [], recentColors: [] };
        const normalized = hex.toLowerCase();
        data.recentColors = [normalized, ...data.recentColors.filter(c => c !== normalized)];
        if (data.recentColors.length > 20) data.recentColors = data.recentColors.slice(0, 20);
        localStorage.setItem('color-helper:saved-palettes', JSON.stringify(data));
      } catch(e) { /* silent */ }
    }

    function savePaletteToStorage(name, colors) {
      try {
        const raw = localStorage.getItem('color-helper:saved-palettes');
        const data = raw ? JSON.parse(raw) : { palettes: [], recentColors: [] };
        const palette = {
          id: Date.now().toString(36) + Math.random().toString(36).slice(2, 8),
          name: name,
          colors: colors.map(c => c.toLowerCase()),
          createdAt: new Date().toISOString(),
          updatedAt: new Date().toISOString(),
          source: 'random',
        };
        data.palettes = [palette, ...data.palettes];
        localStorage.setItem('color-helper:saved-palettes', JSON.stringify(data));
        return true;
      } catch(e) { return false; }
    }

    async function copyToClipboard(text) {
      try { await navigator.clipboard.writeText(text); return true; }
      catch {
        const ta = document.createElement('textarea');
        ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
        document.body.appendChild(ta); ta.select();
        document.execCommand('copy'); document.body.removeChild(ta);
        return true;
      }
    }

    // Single color generation
    const singlePreview = document.getElementById('single-preview');
    const singleHex = document.getElementById('single-hex');
    const singleResultHex = document.getElementById('single-result-hex');
    const singleResultRgb = document.getElementById('single-result-rgb');
    const singleResultHsl = document.getElementById('single-result-hsl');
    const generateSingle = document.getElementById('generate-single');

    function updateSingle(r, g, b) {
      const hex = rgbToHex(r, g, b);
      const hsl = rgbToHsl(r, g, b);
      singlePreview.style.backgroundColor = hex;
      singleHex.textContent = hex;
      singleResultHex.textContent = hex;
      singleResultRgb.textContent = `rgb(${r}, ${g}, ${b})`;
      singleResultHsl.textContent = `hsl(${hsl.h}, ${hsl.s}%, ${hsl.l}%)`;

      // Text contrast
      const lum = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
      singleHex.style.color = lum > 0.5 ? '#1e293b' : '#f1f5f9';
    }

    function generateRandomSingle() {
      const color = randomHexWithMode(currentMode);
      updateSingle(color.r, color.g, color.b);
      addRecentColor(color.hex);
    }

    generateSingle.addEventListener('click', generateRandomSingle);

    // Palette
    const paletteEl = document.getElementById('palette');
    const generatePalette = document.getElementById('generate-palette');
    const savePaletteBtn = document.getElementById('save-palette');
    const saveMsg = document.getElementById('save-msg');

    let paletteColors = [];

    function createSwatch(index) {
      const swatch = document.createElement('div');
      swatch.className = 'palette-swatch';
      swatch.dataset.index = index;

      const colorBox = document.createElement('div');
      colorBox.className = 'palette-color-box';

      const colorLabel = document.createElement('span');
      colorLabel.className = 'palette-color-label';

      const lockBtn = document.createElement('button');
      lockBtn.className = 'palette-lock-btn';
      lockBtn.textContent = '🔓';
      lockBtn.title = 'Lock color';
      lockBtn.dataset.locked = 'false';

      const copyHex = document.createElement('button');
      copyHex.className = 'palette-copy-btn';
      copyHex.textContent = '📋';
      copyHex.title = 'Copy HEX';

      swatch.appendChild(colorBox);
      swatch.appendChild(colorLabel);
      swatch.appendChild(lockBtn);
      swatch.appendChild(copyHex);

      lockBtn.addEventListener('click', function() {
        const locked = this.dataset.locked === 'true';
        this.dataset.locked = locked ? 'false' : 'true';
        this.textContent = locked ? '🔓' : '🔒';
      });

      copyHex.addEventListener('click', async function() {
        const hex = colorLabel.textContent;
        if (hex) {
          const original = this.textContent;
          await copyToClipboard(hex);
          this.textContent = '✓';
          addRecentColor(hex);
          setTimeout(() => { this.textContent = original; }, 1200);
        }
      });

      return swatch;
    }

    function renderPalette(colors) {
      paletteEl.innerHTML = '';
      colors.forEach((c, i) => {
        const swatch = createSwatch(i);
        const colorBox = swatch.querySelector('.palette-color-box');
        const colorLabel = swatch.querySelector('.palette-color-label');
        colorBox.style.backgroundColor = c.hex;
        colorLabel.textContent = c.hex;
        // Adjust text color
        const lum = (0.299 * c.r + 0.587 * c.g + 0.114 * c.b) / 255;
        colorLabel.style.color = lum > 0.5 ? '#1e293b' : '#f1f5f9';
        paletteEl.appendChild(swatch);
      });
    }

    function generatePaletteColors() {
      const existingSwatches = paletteEl.querySelectorAll('.palette-swatch');
      const newColors = [];
      const genFn = accessibleMode ? generateAccessibleColor : randomHexWithMode;
      for (let i = 0; i < 5; i++) {
        let color;
        const existingSwatch = existingSwatches[i];
        if (existingSwatch) {
          const lockBtn = existingSwatch.querySelector('.palette-lock-btn');
          if (lockBtn && lockBtn.dataset.locked === 'true') {
            // Keep existing color
            const label = existingSwatch.querySelector('.palette-color-label');
            const hex = label.textContent;
            const r = parseInt(hex.substring(1, 3), 16);
            const g = parseInt(hex.substring(3, 5), 16);
            const b = parseInt(hex.substring(5, 7), 16);
            color = { r, g, b, hex };
          } else {
            color = genFn(currentMode);
          }
        } else {
          color = genFn(currentMode);
        }
        newColors.push(color);
      }
      paletteColors = newColors;
      renderPalette(paletteColors);

      // Preserve lock states
      existingSwatches.forEach((oldSwatch, i) => {
        const lockBtn = oldSwatch.querySelector('.palette-lock-btn');
        const newSwatch = paletteEl.children[i];
        if (newSwatch) {
          const newLockBtn = newSwatch.querySelector('.palette-lock-btn');
          if (lockBtn && newLockBtn) {
            newLockBtn.dataset.locked = lockBtn.dataset.locked;
            newLockBtn.textContent = lockBtn.textContent;
          }
        }
      });
    }

    generatePalette.addEventListener('click', generatePaletteColors);

    // Mode selector buttons
    document.querySelectorAll('.mode-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        currentMode = this.dataset.mode;
      });
    });

    // Accessible mode toggle
    const accessibleCheckbox = document.getElementById('accessible-mode');
    if (accessibleCheckbox) {
      accessibleCheckbox.addEventListener('change', function() {
        accessibleMode = this.checked;
      });
    }

    // Save palette — uses shared storage
    savePaletteBtn.addEventListener('click', function() {
      const colors = [];
      paletteEl.querySelectorAll('.palette-swatch').forEach(swatch => {
        const label = swatch.querySelector('.palette-color-label');
        if (label) colors.push(label.textContent);
      });
      if (colors.length === 0) return;

      const saved = savePaletteToStorage('Random Palette', colors);
      if (saved) {
        // Also add each color to recent
        colors.forEach(c => addRecentColor(c));
        saveMsg.textContent = '✅ Palette saved to localStorage!';
        saveMsg.style.display = 'block';
        setTimeout(() => { saveMsg.style.display = 'none'; }, 2500);
      }
    });

    // Export: Copy CSS Variables
    const exportCssBtn = document.getElementById('export-css');
    if (exportCssBtn) {
      exportCssBtn.addEventListener('click', async function() {
        const colors = [];
        paletteEl.querySelectorAll('.palette-swatch').forEach(swatch => {
          const label = swatch.querySelector('.palette-color-label');
          if (label) colors.push(label.textContent);
        });
        if (colors.length === 0) return;
        const css = ':root {\n' + formatCSSVariables(colors) + '\n}';
        const original = this.textContent;
        await copyToClipboard(css);
        this.textContent = '✅ Copied CSS';
        this.classList.add('copied');
        setTimeout(() => {
          this.textContent = original;
          this.classList.remove('copied');
        }, 1500);
        colors.forEach(c => addRecentColor(c));
      });
    }

    // Export: Copy JSON
    const exportJsonBtn = document.getElementById('export-json');
    if (exportJsonBtn) {
      exportJsonBtn.addEventListener('click', async function() {
        const colors = [];
        paletteEl.querySelectorAll('.palette-swatch').forEach(swatch => {
          const label = swatch.querySelector('.palette-color-label');
          if (label) colors.push(label.textContent);
        });
        if (colors.length === 0) return;
        const json = formatJSON(colors);
        const original = this.textContent;
        await copyToClipboard(json);
        this.textContent = '✅ Copied JSON';
        this.classList.add('copied');
        setTimeout(() => {
          this.textContent = original;
          this.classList.remove('copied');
        }, 1500);
        colors.forEach(c => addRecentColor(c));
      });
    }

    // Update existing copy buttons to also add to recent colors
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', async function() {
        const targetId = this.getAttribute('data-copy');
        const targetEl = document.getElementById(targetId);
        if (!targetEl) return;
        const text = targetEl.textContent;
        if (!text) return;
        const original = this.textContent;
        await copyToClipboard(text);
        this.textContent = '✓';
        this.classList.add('copied');
        setTimeout(() => {
          this.textContent = original;
          this.classList.remove('copied');
        }, 1200);
        // Extract hex and add to recent
        const hexMatch = text.match(/#[0-9a-fA-F]{6}/);
        if (hexMatch) addRecentColor(hexMatch[0]);
      });
    });

    // Init
    generateRandomSingle();
    generatePaletteColors();
  })();
</script>

<style is:global>
  .tool-wrapper { margin-bottom: 1.5rem; }
  .converter-card {
    max-width: 540px; margin: 0 auto;
    background: #ffffff; border: 1px solid var(--color-border, #e2e8f0);
    border-radius: 14px; padding: 1.5rem;
    box-shadow: 0 4px 6px -1px rgba(0,0,0,0.07), 0 2px 4px -2px rgba(0,0,0,0.05);
  }
  .converter-subtitle { margin: 0 0 0.25rem 0; font-size: 1.125rem; font-weight: 700; letter-spacing: -0.01em; color: var(--color-text-primary, #1e293b); }
  .converter-desc { margin: 0 0 1.25rem 0; font-size: 0.8125rem; color: var(--color-text-secondary, #64748b); }
  .section-block { margin-bottom: 1rem; }
  .section-divider { height: 1px; background: var(--color-border, #e2e8f0); margin: 1.25rem 0; }
  .section-title { font-size: 1rem; font-weight: 700; margin: 0 0 0.75rem 0; color: var(--color-text-primary, #1e293b); }

  /* Single color preview */
  .single-preview {
    width: 100%; height: 120px; border-radius: 12px; border: 2px solid var(--color-border, #e2e8f0);
    display: flex; align-items: flex-end; justify-content: center; padding-bottom: 0.75rem;
    transition: background-color 0.2s ease; margin-bottom: 0.75rem;
  }
  .single-info { background: rgba(255,255,255,0.85); backdrop-filter: blur(4px); border-radius: 8px; padding: 0.375rem 1rem; }
  .single-hex { font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace; font-size: 1rem; font-weight: 700; }

  /* Single outputs */
  .single-outputs { margin-bottom: 1rem; }
  .output-row { display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 0; border-bottom: 1px solid var(--color-border, #e2e8f0); }
  .output-row:last-child { border-bottom: none; }
  .output-label { font-size: 0.6875rem; font-weight: 600; color: var(--color-text-secondary, #64748b); text-transform: uppercase; letter-spacing: 0.05em; width: 36px; flex-shrink: 0; }
  .output-value { flex: 1; font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace; font-size: 0.875rem; font-weight: 600; color: var(--color-text-primary, #1e293b); }

  /* Buttons */
  .action-btn { display: block; width: 100%; padding: 0.625rem; font-size: 0.875rem; font-weight: 600; border: none; border-radius: 10px; background: #6366f1; color: #fff; cursor: pointer; transition: background 0.15s, transform 0.1s; margin-bottom: 0.5rem; }
