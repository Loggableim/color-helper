---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'All Color Tools';
const description = 'Free color tools for designers, developers and creators. Browse all browser-based color utilities — picker, converter, palette generator, contrast checker and more.';
const canonical = 'https://color-helper.com/tools/';
const breadcrumbs = [{ label: 'Tools' }];

const popularSlugs = [
  '/color-picker/',
  '/image-color-picker/',
  '/color-converter/',
  '/contrast-checker/',
  '/color-palette-generator/',
];

const categories = [
  {
    name: 'Pick',
    slug: 'pick',
    description: 'Select and capture colors from anywhere',
    tools: [
      { name: 'Color Picker', href: '/color-picker/', desc: 'Interactive color picker with live preview', icon: '🎨', bestFor: 'Designers' },
      { name: 'Image Color Picker', href: '/image-color-picker/', desc: 'Extract colors from images', icon: '🖼️', bestFor: 'Designers & Developers' },
      { name: 'Random Color', href: '/random-color-generator/', desc: 'Discover random colors instantly', icon: '🎲', bestFor: 'Creatives' },
    ],
  },
  {
    name: 'Convert',
    slug: 'convert',
    description: 'Convert between color formats and notations',
    tools: [
      { name: 'Color Converter', href: '/color-converter/', desc: 'Convert between HEX, RGB and HSL', icon: '🔄', bestFor: 'Developers' },
      { name: 'HEX to RGB', href: '/hex-to-rgb/', desc: 'Convert hex codes to RGB values', icon: '#→R', bestFor: 'Developers' },
      { name: 'RGB to HEX', href: '/rgb-to-hex/', desc: 'Convert RGB values to hex codes', icon: 'R→#', bestFor: 'Developers' },
      { name: 'CSS Converter', href: '/css-color-converter/', desc: 'CSS color format converter', icon: '🎯', bestFor: 'Web Developers' },
      { name: 'RGBA Converter', href: '/rgba-converter/', desc: 'RGBA color conversion tool with opacity', icon: '🔲', bestFor: 'Developers' },
    ],
  },
  {
    name: 'Generate',
    slug: 'generate',
    description: 'Create harmonious color schemes and gradients',
    tools: [
      { name: 'Palette Generator', href: '/color-palette-generator/', desc: 'Generate complementary color palettes', icon: '🌈', bestFor: 'Designers' },
      { name: 'Gradient Generator', href: '/gradient-generator/', desc: 'Create beautiful CSS gradients', icon: '🌊', bestFor: 'Designers & Developers' },
      { name: 'Brand Palette Generator', href: '/color-palette-generator/', desc: 'Build brand color palettes', icon: '🏷️', bestFor: 'Brand Designers' },
      { name: 'Color Mixer', href: '/color-mixer/', desc: 'Mix and blend colors', icon: '🧪', bestFor: 'Artists' },
    ],
  },
  {
    name: 'Check',
    slug: 'check',
    description: 'Ensure accessibility and visual clarity',
    tools: [
      { name: 'Contrast Checker', href: '/contrast-checker/', desc: 'Check WCAG contrast ratios', icon: '👁️', bestFor: 'Accessibility' },
      { name: 'Color Blindness Simulator', href: '/color-blindness-simulator/', desc: 'Simulate color vision deficiencies', icon: '🔍', bestFor: 'Accessibility' },
    ],
  },
  {
    name: 'Learn',
    slug: 'learn',
    description: 'Explore color references and terminology',
    tools: [
      { name: 'Paint Color Matching', href: '/paint-color-matching/', desc: 'Find matching paint colors', icon: '🎨', bestFor: 'DIY & Designers' },
      { name: 'Color Names', href: '/color-picker/', desc: 'Browse named CSS colors', icon: '📋', bestFor: 'Designers' },
      { name: 'HEX Codes', href: '/hex-to-rgb/', desc: 'Comprehensive HEX code reference', icon: '#', bestFor: 'Developers' },
    ],
  },
];

const totalTools = categories.reduce((sum, cat) => sum + cat.tools.length, 0);

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Color Tools - Color Helper",
  "description": description,
  "url": canonical,
};
---

<BaseLayout {title} {description} {canonical} {breadcrumbs}>
  <div class="hub-page">
    <div class="container">
      <div class="hub-header">
        <h1>All Color Tools</h1>
        <p class="hub-subtitle">
          Browse all free browser-based color tools at Color Helper. Pick colors, convert formats,
          generate palettes, check accessibility, and learn about color — everything you need in one place.
        </p>
      </div>

      <!-- Search + Filter Bar -->
      <div class="tools-controls">
        <div class="search-wrapper">
          <span class="search-icon">🔍</span>
          <input
            type="text"
            id="tool-search"
            class="input search-input"
            placeholder="Search tools by name or description..."
            aria-label="Search tools"
          />
          <span class="search-clear" id="search-clear" role="button" tabindex="0" aria-label="Clear search">&times;</span>
        </div>

        <div class="filter-bar" id="filter-bar" role="group" aria-label="Filter by category">
          <button class="filter-pill active" data-filter="all" aria-pressed="true">All Tools <span class="filter-count">{totalTools}</span></button>
          {categories.map((cat) => (
            <button class="filter-pill" data-filter={cat.slug} aria-pressed="false">
              {cat.name} <span class="filter-count">{cat.tools.length}</span>
            </button>
          ))}
        </div>

        <div class="tools-stats">
          <span class="tools-total" id="tools-total">{totalTools}+ tools</span>
          <span class="tools-visible" id="tools-visible" aria-live="polite"></span>
        </div>
      </div>

      <!-- Category Sections -->
      {categories.map((cat) => (
        <section class="tool-category" data-category={cat.slug} id={`cat-${cat.slug}`}>
          <div class="category-header">
            <h2>{cat.name}</h2>
            <p>{cat.description}</p>
          </div>
          <div class="category-grid">
            {cat.tools.map((tool) => {
              const isPopular = popularSlugs.includes(tool.href);
              return (
                <a
                  href={tool.href}
                  class="category-card"
                  data-search={`${tool.name} ${tool.desc} ${tool.bestFor}`}
                  data-popular={isPopular ? 'true' : 'false'}
                >
                  <div class="cat-card-icon">{tool.icon}</div>
                  <div class="cat-card-body">
                    <h3>
                      {tool.name}
                      {isPopular && <span class="popular-badge">Popular</span>}
                    </h3>
                    <p>{tool.desc}</p>
                    <span class="best-for-tag">Best for: {tool.bestFor}</span>
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      ))}

      <!-- Empty state (hidden by default) -->
      <div class="no-results" id="no-results" aria-live="polite" hidden>
        <div class="no-results-icon">🔍</div>
        <h3>No tools found</h3>
        <p>Try a different search term or category filter.</p>
        <button class="btn btn-secondary btn-sm" id="reset-filters">Reset filters</button>
      </div>

      <section class="hub-seo-content">
        <h2>Free Color Tools for Designers and Developers</h2>
        <p>
          Color Helper offers a complete suite of browser-based color tools that work entirely on your device.
          Whether you need to pick a precise color from a spectrum, convert between HEX and RGB formats,
          generate a harmonious palette for your next project, or check that your text meets WCAG accessibility
          standards — every tool is fast, private, and free.
        </p>
        <p>
          All tools run client-side in your browser. No images are uploaded to any server. No tracking scripts
          collect your data. Your work stays on your machine. This makes Color Helper an ideal companion for
          designers who value privacy, developers working with sensitive assets, and accessibility professionals
          auditing client projects.
        </p>
        <p>
          The <a href="/color-picker/">Color Picker</a> and <a href="/image-color-picker/">Image Color Picker</a>
          let you capture colors interactively or extract them from photos. The
          <a href="/color-converter/">Color Converter</a> supports HEX, RGB, and HSL with automatic format
          detection. Build <a href="/color-palette-generator/">color palettes</a> using complementary, analogous,
          or triadic harmony rules, and use the <a href="/contrast-checker/">Contrast Checker</a> to verify
          your designs meet WCAG AA and AAA standards.
        </p>
      </section>

      <section class="hub-faq">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
          <h3>Are all tools really free?</h3>
          <p>Yes. Every tool on Color Helper is completely free. No paid tiers, no subscriptions, no hidden features.</p>
        </div>
        <div class="faq-item">
          <h3>Do I need an account?</h3>
          <p>No account, login, or personal information is required. Just open a tool and start using it.</p>
        </div>
        <div class="faq-item">
          <h3>Which color formats are supported?</h3>
          <p>HEX, RGB, HSL, and RGBA are supported across all relevant tools. The Color Converter handles all formats in one place.</p>
        </div>
        <div class="faq-item">
          <h3>Do you store my images?</h3>
          <p>No. Images are processed entirely in your browser. Nothing is ever uploaded to any server.</p>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(webAppSchema)}></script>

<script>
  (function () {
    const searchInput = document.getElementById('tool-search');
    const searchClear = document.getElementById('search-clear');
    const filterBar = document.getElementById('filter-bar');
    const filterPills = filterBar.querySelectorAll('.filter-pill');
    const sections = document.querySelectorAll('.tool-category');
    const noResults = document.getElementById('no-results');
    const resetBtn = document.getElementById('reset-filters');
    const toolsTotal = document.getElementById('tools-total');
    const toolsVisible = document.getElementById('tools-visible');
    const allCards = document.querySelectorAll('.category-card');

    let currentFilter = 'all';
    let currentQuery = '';
    let debounceTimer = null;

    function getVisibleCount() {
      let count = 0;
      allCards.forEach(function (card) {
        if (!card.hasAttribute('hidden')) count++;
      });
      return count;
    }

    function updateVisibleCount() {
      const visible = getVisibleCount();
      const total = allCards.length;

      // Update the total stat to show both numbers
      const statEl = document.querySelector('.tools-stats');
      if (currentQuery || currentFilter !== 'all') {
        toolsVisible.textContent = visible + ' of ' + total + ' tools shown';
        toolsVisible.style.display = 'inline';
      } else {
        toolsVisible.style.display = 'none';
        toolsVisible.textContent = '';
      }
    }

    function applyFilters() {
      const query = currentQuery.toLowerCase().trim();
      let anyVisible = false;

      allCards.forEach(function (card) {
        const searchData = (card.getAttribute('data-search') || '').toLowerCase();
        const parentSection = card.closest('.tool-category');
        const catSlug = parentSection ? parentSection.getAttribute('data-category') : '';

        // Check search match
        let searchMatch = true;
        if (query) {
          searchMatch = searchData.indexOf(query) !== -1;
        }

        // Check category filter
        let catMatch = true;
        if (currentFilter !== 'all') {
          catMatch = catSlug === currentFilter;
        }

        const visible = searchMatch && catMatch;
        card.hidden = !visible;
        if (visible) anyVisible = true;
      });

      // Show/hide category sections based on whether they have any visible children
      sections.forEach(function (section) {
        const cards = section.querySelectorAll('.category-card');
        let hasVisible = false;
        cards.forEach(function (c) {
          if (!c.hidden) hasVisible = true;
        });
        section.style.display = hasVisible ? '' : 'none';
      });

      // No results state
      if (!anyVisible) {
        noResults.removeAttribute('hidden');
      } else {
        noResults.setAttribute('hidden', '');
      }

      updateVisibleCount();
    }

    // --- Search input ---
    if (searchInput) {
      searchInput.addEventListener('input', function () {
        if (debounceTimer) clearTimeout(debounceTimer);
        debounceTimer = setTimeout(function () {
          currentQuery = searchInput.value;
          searchClear.style.display = currentQuery ? 'flex' : 'none';
          applyFilters();
        }, 150);
      });

      // Clear search
      if (searchClear) {
        searchClear.addEventListener('click', function () {
          searchInput.value = '';
          searchClear.style.display = 'none';
          currentQuery = '';
          applyFilters();
          searchInput.focus();
        });
        searchClear.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            searchInput.value = '';
            searchClear.style.display = 'none';
            currentQuery = '';
            applyFilters();
            searchInput.focus();
          }
        });
      }
    }

    // --- Filter pills ---
    filterPills.forEach(function (pill) {
      pill.addEventListener('click', function () {
        // Update active state
        filterPills.forEach(function (p) {
          p.classList.remove('active');
          p.setAttribute('aria-pressed', 'false');
        });
        pill.classList.add('active');
        pill.setAttribute('aria-pressed', 'true');

        currentFilter = pill.getAttribute('data-filter');
        applyFilters();
      });
    });

    // --- Reset button ---
    if (resetBtn) {
      resetBtn.addEventListener('click', function () {
        // Reset search
        if (searchInput) {
          searchInput.value = '';
          searchClear.style.display = 'none';
        }
        currentQuery = '';

        // Reset filter to 'all'
        filterPills.forEach(function (p) {
          p.classList.remove('active');
          p.setAttribute('aria-pressed', 'false');
        });
        const allPill = filterBar.querySelector('[data-filter="all"]');
        if (allPill) {
          allPill.classList.add('active');
          allPill.setAttribute('aria-pressed', 'true');
        }
        currentFilter = 'all';

        applyFilters();
        if (searchInput) searchInput.focus();
      });
    }

    // Initial state
    updateVisibleCount();
  })();
</script>

<style is:global>
  /* ---- Search & Controls ---- */
  .tools-controls {
    margin-bottom: 2.5rem;
  }

  .search-wrapper {
    position: relative;
    max-width: 480px;
    margin: 0 auto 1.25rem;
  }

  .search-icon {
    position: absolute;
    left: 0.875rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1rem;
    pointer-events: none;
    opacity: 0.5;
    line-height: 1;
  }

  .search-input {
    padding-left: 2.75rem !important;
    padding-right: 2.5rem !important;
    height: 48px;
    font-size: 0.9375rem;
    border-radius: var(--radius-lg) !important;
    background: var(--color-bg-card);
    border: 1.5px solid var(--color-border);
    transition: border-color 0.25s var(--ease-out-expo), box-shadow 0.25s var(--ease-out-expo);
  }

  .search-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 4px rgba(124, 58, 237, 0.1);
  }

  .search-clear {
    position: absolute;
    right: 0.625rem;
    top: 50%;
    transform: translateY(-50%);
    width: 28px;
    height: 28px;
    display: none;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    color: var(--color-text-muted);
    cursor: pointer;
    border-radius: var(--radius-full);
    transition: background 0.2s, color 0.2s;
    line-height: 1;
    user-select: none;
  }

  .search-clear:hover {
    background: var(--color-primary-subtle);
    color: var(--color-primary);
  }

  .search-clear:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* ---- Filter Bar ---- */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .filter-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
    font-weight: 600;
    font-family: var(--font-sans);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-full);
    background: var(--color-bg-card);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 0.25s var(--ease-out-expo);
    white-space: nowrap;
    user-select: none;
  }

  .filter-pill:hover {
    border-color: var(--color-primary-lighter);
    color: var(--color-primary);
    background: var(--color-primary-subtle);
  }

  .filter-pill.active {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    border-color: transparent;
    color: white;
    box-shadow: 0 2px 8px rgba(124, 58, 237, 0.3);
  }

  .filter-pill.active:hover {
    box-shadow: 0 4px 14px rgba(124, 58, 237, 0.4);
    color: white;
  }

  .filter-pill:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .filter-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 20px;
    padding: 0 0.375rem;
    font-size: 0.6875rem;
    font-weight: 700;
    border-radius: var(--radius-full);
    background: rgba(0, 0, 0, 0.08);
  }

  .filter-pill.active .filter-count {
    background: rgba(255, 255, 255, 0.2);
  }

  /* ---- Tools Stats ---- */
  .tools-stats {
    text-align: center;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .tools-total {
    font-weight: 700;
    color: var(--color-text);
    font-size: 0.9375rem;
  }

  .tools-visible {
    display: none;
    margin-left: 0.5rem;
    color: var(--color-text-secondary);
  }

  /* ---- Category Header ---- */
  .tool-category {
    margin-bottom: 3rem;
    transition: opacity 0.2s var(--ease-out-expo);
  }

  .category-header {
    margin-bottom: 1.25rem;
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .category-header h2 {
    font-size: 1.5rem;
    margin-bottom: 0;
  }

  .category-header p {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
  }

  /* ---- Category Grid ---- */
  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.875rem;
  }

  /* ---- Category Card ---- */
  .category-card {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 1rem 1.125rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-text);
    transition: box-shadow 0.25s var(--ease-out-expo), transform 0.25s var(--ease-out-expo), border-color 0.25s var(--ease-out-expo);
    position: relative;
  }

  .category-card:hover {
    box-shadow: var(--shadow-ring-hover), var(--shadow-md);
    transform: translateY(-2px);
    border-color: var(--color-primary-lighter);
  }

  .category-card[hidden] {
    display: none;
  }

  .cat-card-icon {
    font-size: 1.5rem;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: var(--color-primary-subtle);
    border-radius: var(--radius-sm);
  }

  .cat-card-body {
    flex: 1;
    min-width: 0;
  }

  .cat-card-body h3 {
    font-size: 0.9375rem;
    font-weight: 600;
    margin-bottom: 0.1875rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .cat-card-body p {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
    margin-bottom: 0.375rem;
  }

  /* ---- Best For Tag ---- */
  .best-for-tag {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-primary);
    background: var(--color-primary-subtle);
    padding: 0.1875rem 0.5625rem;
    border-radius: var(--radius-sm);
    letter-spacing: 0.01em;
    line-height: 1.3;
  }

  /* ---- Popular Badge ---- */
  .popular-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.1875rem 0.5rem;
    border-radius: var(--radius-sm);
    background: linear-gradient(135deg, #f59e0b, #f97316);
    color: white;
    line-height: 1.2;
    position: relative;
    top: -1px;
  }

  /* ---- No Results ---- */
  .no-results {
    text-align: center;
    padding: 3rem 1.5rem;
    background: var(--color-bg-card);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
    margin-bottom: 3rem;
  }

  .no-results[hidden] {
    display: none;
  }

  .no-results-icon {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
    opacity: 0.4;
  }

  .no-results h3 {
    font-size: 1.125rem;
    margin-bottom: 0.375rem;
  }

  .no-results p {
    color: var(--color-text-secondary);
    margin-bottom: 1.25rem;
    font-size: 0.875rem;
  }

  /* ---- Hub Header (unchanged) ---- */
  .hub-page {
    padding: 2rem 0 4rem;
  }

  .hub-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .hub-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .hub-subtitle {
    max-width: 640px;
    margin: 0 auto;
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  /* ---- FAQ and SEO (unchanged) ---- */
  .hub-seo-content {
    max-width: 680px;
    margin: 3rem auto;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .hub-seo-content h2 {
    font-size: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .hub-seo-content p {
    margin-bottom: 1.125rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
  }

  .hub-seo-content a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .hub-faq {
    max-width: 680px;
    margin: 0 auto;
  }

  .hub-faq h2 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .faq-item {
    margin-bottom: 1.5rem;
  }

  .faq-item h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 0.375rem;
  }

  .faq-item p {
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  /* ---- Responsive Tweaks ---- */
  @media (max-width: 640px) {
    .filter-bar {
      gap: 0.375rem;
    }
    .filter-pill {
      padding: 0.4rem 0.75rem;
      font-size: 0.75rem;
    }
    .category-header {
      flex-direction: column;
      gap: 0.25rem;
    }
    .category-header h2 {
      font-size: 1.25rem;
    }
    .search-wrapper {
      max-width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .category-card,
    .filter-pill,
    .search-input {
      transition: none !important;
    }
  }
</style>
