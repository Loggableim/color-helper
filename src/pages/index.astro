---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard, {
  EYEDROPPER_ICON,
  IMAGE_ICON,
  ARROWS_ICON,
  CONTRAST_ICON,
  PALETTE_ICON,
  GRADIENT_ICON,
  NAMES_ICON,
  SHUFFLE_ICON,
  MIXER_ICON,
  CSS_ICON,
  RGBA_ICON,
  EYE_ICON,
  HEX_RGB_ICON,
  RGB_HEX_ICON,
} from '../components/ToolCard.astro';
import FAQ from '../components/FAQ.astro';
---

<BaseLayout
  title="Color Helper"
  description="Free color tools for designers, developers and creators. Pick, convert, check and generate colors in your browser — no uploads, no accounts, no tracking."
  canonical="https://color-helper.com/"
>
  <!-- ============================================================
       HERO — 2 Columns on Desktop
       ============================================================ -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <div class="hero-badge">Free browser-based color tools</div>
        <h1>Color tools that stay out of your way</h1>
        <p class="hero-subtitle">Pick, convert, check and generate colors faster — all in your browser. No uploads, no accounts, no tracking.</p>
        <div class="hero-actions">
          <a href="/color-picker/" class="btn btn-primary hero-cta-primary">Open Color Picker</a>
          <a href="/image-color-picker/" class="btn btn-secondary hero-cta-secondary">Try Image Picker</a>
        </div>
        <div class="hero-trust">
          <span>No account</span><span class="sep">·</span><span>No uploads</span><span class="sep">·</span><span>Runs in browser</span>
        </div>
      </div>
      <div class="hero-preview">
        <!-- Premium Tool Preview Card -->
        <div class="tool-preview-card" id="hero-preview">
          <div class="preview-swatch" style="background: #7C3AED;">
            <span class="preview-hex-label">#7C3AED</span>
          </div>
          <div class="preview-values">
            <div class="pv-row"><span class="pv-label">HEX</span><span class="pv-value">#7C3AED</span></div>
            <div class="pv-row"><span class="pv-label">RGB</span><span class="pv-value">124, 58, 237</span></div>
            <div class="pv-row"><span class="pv-label">HSL</span><span class="pv-value">262°, 83%, 58%</span></div>
          </div>
          <div class="preview-swatches">
            <span style="background:#7C3AED"></span>
            <span style="background:#06B6D4"></span>
            <span style="background:#EC4899"></span>
            <span style="background:#F97316"></span>
            <span style="background:#10B981"></span>
          </div>
          <div class="preview-actions">
            <button class="preview-btn">Copy HEX</button>
            <button class="preview-btn preview-btn-primary">Generate Palette</button>
          </div>
        </div>
        <script>
          // Rotate the preview color in hero
          (() => {
            const colors = ['#7C3AED','#06B6D4','#EC4899','#F97316','#10B981'];
            const swatch = document.querySelector('.preview-swatch');
            const hexLabel = document.querySelector('.preview-hex-label');
            const pvValues = document.querySelectorAll('.pv-value');
            let i = 0;
            setInterval(() => {
              i = (i + 1) % colors.length;
              const c = colors[i];
              if (swatch) swatch.style.background = c;
              if (hexLabel) hexLabel.textContent = c;
              // Parse and update
              const r = parseInt(c.slice(1,3),16);
              const g = parseInt(c.slice(3,5),16);
              const b = parseInt(c.slice(5,7),16);
              // HSL
              const rr=r/255,gg=g/255,bb=b/255;
              const max=Math.max(rr,gg,bb),min=Math.min(rr,gg,bb);
              const l=(max+min)/2;
              const d=max-min;
              let h=0,s=0;
              if(d!==0){
                s=l>0.5?d/(2-max-min):d/(max+min);
                if(max===rr)h=((gg-bb)/d+(gg<bb?6:0))*60;
                else if(max===gg)h=((bb-rr)/d+2)*60;
                else h=((rr-gg)/d+4)*60;
              }
              if(pvValues.length>=3){
                pvValues[0].textContent=c;
                pvValues[1].textContent=`${r}, ${g}, ${b}`;
                pvValues[2].textContent=`${Math.round(h)}°, ${Math.round(s*100)}%, ${Math.round(l*100)}%`;
              }
            }, 2500);
          })();
        </script>
      </div>
    </div>
  </section>

  <!-- ============================================================
       TOOL CATEGORIES — Pick, Convert, Generate, Check, Learn
       ============================================================ -->
  <section class="section categories-section">
    <div class="container">
      <div class="section-header fade-in">
        <h2>All Tools</h2>
        <p>Five categories covering everything you need to work with color.</p>
      </div>
      <div class="categories-grid">
        <!-- Pick -->
        <div class="category-card fade-in fade-in-delay-1">
          <div class="cat-icon" style="background: linear-gradient(135deg, #7C3AED, #A78BFA);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33"/>
              <path d="M14.86 17.65a2 2 0 0 1 0 2.83l-.22.22a2 2 0 0 1-4.24-.1 2 2 0 0 1 .1-4.24l.22-.22a2 2 0 0 1 2.83 0z"/><path d="M8.5 11.5l-5 5"/><path d="M6 17l-1.5 1.5"/>
              <path d="M11.5 8.5l5-5"/><path d="M17 6l1.5-1.5"/><path d="M8.5 3.5l-5 5"/><path d="M9 9l-5-5"/>
            </svg>
          </div>
          <h3 class="cat-title">Pick</h3>
          <ul class="cat-tools">
            <li><a href="/color-picker/">Color Picker</a></li>
            <li><a href="/image-color-picker/">Image Color Picker</a></li>
            <li><a href="/random-color-generator/">Random Color</a></li>
            <li><a href="/color-names/">Color Names</a></li>
          </ul>
        </div>
        <!-- Convert -->
        <div class="category-card fade-in fade-in-delay-2">
          <div class="cat-icon" style="background: linear-gradient(135deg, #06B6D4, #22D3EE);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/>
              <polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/>
            </svg>
          </div>
          <h3 class="cat-title">Convert</h3>
          <ul class="cat-tools">
            <li><a href="/color-converter/">Color Converter</a></li>
            <li><a href="/hex-to-rgb/">HEX to RGB</a></li>
            <li><a href="/rgb-to-hex/">RGB to HEX</a></li>
            <li><a href="/css-color-converter/">CSS Color Converter</a></li>
          </ul>
        </div>
        <!-- Generate -->
        <div class="category-card fade-in fade-in-delay-3">
          <div class="cat-icon" style="background: linear-gradient(135deg, #EC4899, #F472B6);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3a6 6 0 0 0-6 6c0 4 6 12 6 12s6-8 6-12a6 6 0 0 0-6-6z"/>
              <circle cx="12" cy="9" r="2"/>
            </svg>
          </div>
          <h3 class="cat-title">Generate</h3>
          <ul class="cat-tools">
            <li><a href="/color-palette-generator/">Palette Generator</a></li>
            <li><a href="/gradient-generator/">Gradient Generator</a></li>
            <li><a href="/color-mixer/">Color Mixer</a></li>
            <li><a href="/rgba-converter/">RGBA Converter</a></li>
          </ul>
        </div>
        <!-- Check -->
        <div class="category-card fade-in fade-in-delay-1">
          <div class="cat-icon" style="background: linear-gradient(135deg, #F97316, #FB923C);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
            </svg>
          </div>
          <h3 class="cat-title">Check</h3>
          <ul class="cat-tools">
            <li><a href="/contrast-checker/">Contrast Checker</a></li>
            <li><a href="/color-blindness-simulator/">Blindness Sim</a></li>
          </ul>
        </div>
        <!-- Learn -->
        <div class="category-card fade-in fade-in-delay-2">
          <div class="cat-icon" style="background: linear-gradient(135deg, #10B981, #34D399);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
            </svg>
          </div>
          <h3 class="cat-title">Learn</h3>
          <ul class="cat-tools">
            <li><a href="/colors/">Color Encyclopedia</a></li>
            <li><a href="/color-names/">Color Names</a></li>
            <li><a href="/hex-color-codes/">HEX Codes</a></li>
            <li><a href="/guides/">Guides &amp; Resources</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       POPULAR TOOLS — 6 ToolCards with SVG icons via slot
       ============================================================ -->
  <section class="section popular-section">
    <div class="container">
      <div class="section-header fade-in">
        <h2>Popular Tools</h2>
        <p>The most used color utilities on Color Helper.</p>
      </div>
      <div class="tool-grid fade-in fade-in-delay-1">
        <ToolCard
          title="Color Picker"
          description="Pick and save colors with an interactive color picker"
          href="/color-picker/"
          gradient="linear-gradient(135deg, #7C3AED, #A78BFA)"
        >
          <svg slot="icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33"/>
            <path d="M14.86 17.65a2 2 0 0 1 0 2.83l-.22.22a2 2 0 0 1-4.24-.1 2 2 0 0 1 .1-4.24l.22-.22a2 2 0 0 1 2.83 0z"/><path d="M8.5 11.5l-5 5"/><path d="M6 17l-1.5 1.5"/>
            <path d="M11.5 8.5l5-5"/><path d="M17 6l1.5-1.5"/><path d="M8.5 3.5l-5 5"/><path d="M9 9l-5-5"/>
          </svg>
        </ToolCard>
        <ToolCard
          title="Image Color Picker"
          description="Extract colors from any image directly in your browser"
          href="/image-color-picker/"
          gradient="linear-gradient(135deg, #EC4899, #F472B6)"
        >
          <svg slot="icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
          </svg>
        </ToolCard>
        <ToolCard
          title="Color Converter"
          description="Convert between HEX, RGB, and HSL color formats in one place"
          href="/color-converter/"
          gradient="linear-gradient(135deg, #06B6D4, #22D3EE)"
        >
          <svg slot="icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/>
            <polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/>
          </svg>
        </ToolCard>
        <ToolCard
          title="Contrast Checker"
          description="Check WCAG accessibility contrast ratios for AA and AAA compliance"
          href="/contrast-checker/"
          gradient="linear-gradient(135deg, #F97316, #FB923C)"
        >
          <svg slot="icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
          </svg>
        </ToolCard>
        <ToolCard
          title="Palette Generator"
          description="Generate complementary, analogous and triadic color palettes"
          href="/color-palette-generator/"
          gradient="linear-gradient(135deg, #10B981, #34D399)"
        >
          <svg slot="icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3a6 6 0 0 0-6 6c0 4 6 12 6 12s6-8 6-12a6 6 0 0 0-6-6z"/><circle cx="12" cy="9" r="2"/>
          </svg>
        </ToolCard>
        <ToolCard
          title="Gradient Generator"
          description="Create beautiful CSS gradients with live preview"
          href="/gradient-generator/"
          gradient="linear-gradient(135deg, #6366f1, #A855F7)"
        >
          <svg slot="icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
            <line x1="12" y1="22.08" x2="12" y2="12"/>
          </svg>
        </ToolCard>
      </div>
    </div>
  </section>

  <!-- ============================================================
       RECENTLY ADDED — Smaller cards list
       ============================================================ -->
  <section class="section recently-section">
    <div class="container">
      <div class="section-header fade-in">
        <h2>Recently Added</h2>
        <p>Fresh tools just shipped — try them out.</p>
      </div>
      <div class="recent-grid fade-in fade-in-delay-1">
        <a href="/color-names/" class="recent-card">
          <span class="recent-card-icon" style="background: linear-gradient(135deg, #EAB308, #FACC15);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
          </span>
          <span class="recent-card-body">
            <span class="recent-card-title">Color Names</span>
            <span class="recent-card-desc">Browse all CSS named colors</span>
          </span>
        </a>
        <a href="/random-color-generator/" class="recent-card">
          <span class="recent-card-icon" style="background: linear-gradient(135deg, #8B5CF6, #A78BFA);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="8" height="8" rx="2"/><rect x="14" y="2" width="8" height="8" rx="2"/>
              <rect x="2" y="14" width="8" height="8" rx="2"/><rect x="14" y="14" width="8" height="8" rx="2"/>
            </svg>
          </span>
          <span class="recent-card-body">
            <span class="recent-card-title">Random Color</span>
            <span class="recent-card-desc">Generate random colors and palettes</span>
          </span>
        </a>
        <a href="/color-mixer/" class="recent-card">
          <span class="recent-card-icon" style="background: linear-gradient(135deg, #F43F5E, #FB7185);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3a6 6 0 0 0-6 6c0 4 6 12 6 12s6-8 6-12a6 6 0 0 0-6-6z"/><circle cx="12" cy="9" r="2"/>
            </svg>
          </span>
          <span class="recent-card-body">
            <span class="recent-card-title">Color Mixer</span>
            <span class="recent-card-desc">Mix two colors and see the result</span>
          </span>
        </a>
        <a href="/color-blindness-simulator/" class="recent-card">
          <span class="recent-card-icon" style="background: linear-gradient(135deg, #3B82F6, #60A5FA);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
            </svg>
          </span>
          <span class="recent-card-body">
            <span class="recent-card-title">Blindness Sim</span>
            <span class="recent-card-desc">Simulate color vision deficiency</span>
          </span>
        </a>
        <a href="/rgba-converter/" class="recent-card">
          <span class="recent-card-icon" style="background: linear-gradient(135deg, #22C55E, #4ADE80);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><line x1="4" y1="4" x2="9" y2="9"/>
            </svg>
          </span>
          <span class="recent-card-body">
            <span class="recent-card-title">RGBA Converter</span>
            <span class="recent-card-desc">Colors with opacity to RGBA</span>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       WHY COLOR HELPER — 3 Benefits
       ============================================================ -->
  <section class="section why-section">
    <div class="container">
      <div class="section-header fade-in">
        <h2>Why Color Helper?</h2>
        <p>Built differently so you can work better with color.</p>
      </div>
      <div class="benefits-grid">
        <div class="benefit-card fade-in fade-in-delay-1">
          <div class="benefit-icon" style="background: var(--color-primary-subtle); color: var(--color-primary);">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <h3>Privacy-First</h3>
          <p>Everything runs in your browser. No uploads, no servers, no tracking. Your data never leaves your device.</p>
        </div>
        <div class="benefit-card fade-in fade-in-delay-2">
          <div class="benefit-icon" style="background: rgba(6, 182, 212, 0.1); color: var(--color-accent-cyan);">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
          </div>
          <h3>Fast &amp; Lightweight</h3>
          <p>Instant responses with no waiting. No account needed, no subscription. Zero configuration, zero bloat.</p>
        </div>
        <div class="benefit-card fade-in fade-in-delay-3">
          <div class="benefit-icon" style="background: rgba(16, 185, 129, 0.1); color: var(--color-success);">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
            </svg>
          </div>
          <h3>Developer Friendly</h3>
          <p>Copy-ready CSS values, WCAG compliance checks, and precise color conversions that fit right into your workflow.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       COLOR RESOURCES — Links section
       ============================================================ -->
  <section class="section resources-section">
    <div class="container">
      <div class="section-header fade-in">
        <h2>Color Resources</h2>
        <p>Explore our library of color knowledge and reference pages.</p>
      </div>
      <div class="resources-grid fade-in fade-in-delay-1">
        <a href="/colors/" class="resource-card">
          <div class="resource-card-icon" style="background: linear-gradient(135deg, #7C3AED, #A78BFA);">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/>
            </svg>
          </div>
          <span class="resource-card-title">Color Encyclopedia</span>
          <span class="resource-card-desc">Comprehensive guide to named colors, hex codes, and color theory.</span>
          <span class="resource-card-arrow">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>
        <a href="/color-names/" class="resource-card">
          <div class="resource-card-icon" style="background: linear-gradient(135deg, #EAB308, #FACC15);">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
            </svg>
          </div>
          <span class="resource-card-title">CSS Color Names</span>
          <span class="resource-card-desc">All 148 CSS named colors with swatches and hex values.</span>
          <span class="resource-card-arrow">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>
        <a href="/hex-color-codes/" class="resource-card">
          <div class="resource-card-icon" style="background: linear-gradient(135deg, #06B6D4, #22D3EE);">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
            </svg>
          </div>
          <span class="resource-card-title">HEX Color Codes</span>
          <span class="resource-card-desc">Searchable database of hex color codes with previews.</span>
