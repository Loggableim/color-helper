---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard, {
  EYEDROPPER_ICON,
  IMAGE_ICON,
  ARROWS_ICON,
  CONTRAST_ICON,
  PALETTE_ICON,
  GRADIENT_ICON,
  NAMES_ICON,
  SHUFFLE_ICON,
  MIXER_ICON,
  CSS_ICON,
  RGBA_ICON,
  EYE_ICON,
  HEX_RGB_ICON,
  RGB_HEX_ICON,
  BRAND_ICON,
  WHEEL_ICON,
} from '../components/ToolCard.astro';
import FAQ from '../components/FAQ.astro';
import { colors } from '../data/colors';

// Color of the Day — deterministic per day-of-year, changes daily at midnight
const dayOfYear = Math.floor(
  (Date.now() - new Date(new Date().getFullYear(), 0, 0).getTime()) / 86400000
);
const colorOfTheDay = colors[dayOfYear % colors.length];

// Source of truth for color counts — derived from the colors data.
// 141 entries; 139 unique hex values (CSS-synonym pairs share: aqua=cyan, fuchsia=magenta).
const totalColors = colors.length;
const uniqueHex = new Set(colors.map((c) => c.hex.toLowerCase())).size;
---

<BaseLayout
  title="Color Helper"
  description="Free color tools for designers, developers and creators. Pick, convert, check and generate colors in your browser — your images and palettes stay in your browser, no account required, no image uploads."
  canonical="https://color-helper.com/"
>
  <!-- ================================================================
       HERO — 2 Columns: Copy + Live Tool Preview
       ================================================================ -->
  <section class="hero">
    <!-- Subtle background ambiance -->
    <div class="hero-bg-glow" aria-hidden="true"></div>
    <div class="container">
      <div class="hero-grid">
        <!-- Left: Copy -->
        <div class="hero-copy">
          <span class="hero-badge">Free browser-based color tools</span>
          <h1>Color tools that<br class="hide-mobile" /> stay out of your way</h1>
          <p class="hero-subtitle">
            Pick, convert, check and generate colors faster — all in your browser.
            Your images and palettes stay on your device, no account required.
          </p>
          <div class="hero-actions">
            <a href="/color-picker/" class="btn btn-primary hero-cta-primary">Open Color Picker</a>
            <a href="/image-color-picker/" class="btn btn-secondary hero-cta-secondary">Try Image Picker</a>
          </div>
          <div class="hero-trust">
            <span class="trust-chip">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              No account
            </span>
            <span class="trust-chip">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-9-9" opacity="0.5"/><path d="M12 6v6l4 2"/></svg>
              No uploads
            </span>
            <span class="trust-chip">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
              Runs in browser
            </span>
          </div>
          <!-- Color of the Day -->
          <a href={`/colors/${colorOfTheDay.slug}/`} class="cotd-badge" aria-label={`Color of the Day: ${colorOfTheDay.name}`}>
            <span class="cotd-label">🎨 Color of the Day</span>
            <span class="cotd-swatch" style={`background-color: ${colorOfTheDay.hex};`}></span>
            <span class="cotd-name">{colorOfTheDay.name}</span>
            <span class="cotd-hex">{colorOfTheDay.hex}</span>
            <span class="cotd-arrow" aria-hidden="true">→</span>
          </a>
        </div>
        <!-- Right: Live Tool Preview Card -->
        <div class="hero-preview">
          <div class="tool-preview-card" id="hero-preview">
            <!-- Color Swatch -->
            <div class="preview-swatch" style="background: #7C3AED;">
              <span class="preview-hex-label" id="hero-hex-label">#7C3AED</span>
            </div>
            <!-- Values -->
            <div class="preview-values">
              <div class="pv-row"><span class="pv-label">HEX</span><span class="pv-value" id="pv-hex">#7C3AED</span></div>
              <div class="pv-row"><span class="pv-label">RGB</span><span class="pv-value" id="pv-rgb">124, 58, 237</span></div>
              <div class="pv-row"><span class="pv-label">HSL</span><span class="pv-value" id="pv-hsl">262°, 83%, 58%</span></div>
            </div>
            <!-- Palette -->
            <div class="preview-swatches">
              <span style="background:#7C3AED"></span>
              <span style="background:#06B6D4"></span>
              <span style="background:#EC4899"></span>
              <span style="background:#F97316"></span>
              <span style="background:#10B981"></span>
            </div>
            <!-- Actions -->
            <div class="preview-actions">
              <button class="preview-btn preview-btn-copy" id="preview-copy-btn">Copy HEX</button>
              <a href="/color-palette-generator/" class="preview-btn preview-btn-primary">Generate Palette</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Rotate preview color every 3s -->
  <script>
    (() => {
      const colors = ['#7C3AED','#06B6D4','#EC4899','#F97316','#10B981'];
      const swatch = document.querySelector('.preview-swatch');
      const hexLabel = document.getElementById('hero-hex-label');
      const pvHex = document.getElementById('pv-hex');
      const pvRgb = document.getElementById('pv-rgb');
      const pvHsl = document.getElementById('pv-hsl');
      let i = 0;
      setInterval(() => {
        i = (i + 1) % colors.length;
        const c = colors[i];
        if (swatch) swatch.style.background = c;
        if (hexLabel) hexLabel.textContent = c;
        const r = parseInt(c.slice(1,3),16);
        const g = parseInt(c.slice(3,5),16);
        const b = parseInt(c.slice(5,7),16);
        const rr=r/255,gg=g/255,bb=b/255;
        const max=Math.max(rr,gg,bb),min=Math.min(rr,gg,bb);
        const l=(max+min)/2;
        const d=max-min;
        let h=0,s=0;
        if(d!==0){
          s=l>0.5?d/(2-max-min):d/(max+min);
          if(max===rr)h=((gg-bb)/d+(gg<bb?6:0))*60;
          else if(max===gg)h=((bb-rr)/d+2)*60;
          else h=((rr-gg)/d+4)*60;
        }
        if (pvHex) pvHex.textContent = c;
        if (pvRgb) pvRgb.textContent = `${r}, ${g}, ${b}`;
        if (pvHsl) pvHsl.textContent = `${Math.round(h)}°, ${Math.round(s*100)}%, ${Math.round(l*100)}%`;
      }, 3000);

      // Copy HEX button
      const copyBtn = document.getElementById('preview-copy-btn');
      if (copyBtn) {
        copyBtn.addEventListener('click', () => {
          const hex = document.getElementById('hero-hex-label')?.textContent || '#7C3AED';
          navigator.clipboard.writeText(hex).then(() => {
            const orig = copyBtn.textContent;
            copyBtn.textContent = 'Copied!';
            setTimeout(() => { copyBtn.textContent = orig; }, 1500);
          }).catch(() => {});
        });
      }
    })();
  </script>

