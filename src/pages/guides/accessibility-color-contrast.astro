const canonical = 'https://color-helper.com/guides/accessibility-color-contrast/';
const breadcrumbs = [
  { label: 'Guides', href: '/guides/' },
  { label: 'Accessibility Color Contrast' },
];

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        { "@type": "Question", "name": "AA vs AAA?", "acceptedAnswer": { "@type": "Answer", "text": "AA: 4.5:1 text. AAA: 7:1 text. AA is legal minimum." } },
        { "@type": "Question", "name": "Does non-text need contrast?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, WCAG 2.1 requires 3:1 for UI components." } },
        { "@type": "Question", "name": "How to fix failing contrast?", "acceptedAnswer": { "@type": "Answer", "text": "Darken foreground, lighten background, or increase font size." } },
        { "@type": "Question", "name": "Can low-contrast work for large text?", "acceptedAnswer": { "@type": "Answer", "text": "Large text (>=18pt) needs 3:1 for AA. AAA still needs 4.5:1." } },
        { "@type": "Question", "name": "Best way to check contrast?", "acceptedAnswer": { "@type": "Answer", "text": "Use the Contrast Checker during design." } }
    ]
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "author": { "@type": "Organization", "name": "Color Helper" },
  "publisher": { "@type": "Organization", "name": "Color Helper" },
  "url": canonical,
  "mainEntityOfPage": canonical,
  "datePublished": "2025-01-18",
  "dateModified": "2025-03-01",
