            <li><a href="#introduction">Introduction</a></li>
            <li><a href="#choosing-a-palette">Choosing a Palette</a></li>
            <li><a href="#accessibility-first">Accessibility First</a></li>
            <li><a href="#brand-consistency">Brand Consistency</a></li>
            <li><a href="#color-in-ui">Color in UI Design</a></li>
            <li><a href="#trends">Color Trends</a></li>
            <li><a href="#tools-to-use">Tools to Use</a></li>
            <li><a href="#faq">FAQ</a></li>
          </ol>
