        { "@type": "Question", "name": "How to maintain brand consistency?", "acceptedAnswer": { "@type": "Answer", "text": "Use CSS custom properties for your palette." } },
        { "@type": "Question", "name": "How many colors for a website?", "acceptedAnswer": { "@type": "Answer", "text": "3 to 5 core colors." } },
        { "@type": "Question", "name": "Light or dark mode first?", "acceptedAnswer": { "@type": "Answer", "text": "Design light mode first, adapt for dark." } }
    ]
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "author": { "@type": "Organization", "name": "Color Helper" },
  "publisher": { "@type": "Organization", "name": "Color Helper" },
