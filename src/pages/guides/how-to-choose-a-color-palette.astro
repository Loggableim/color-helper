    "mainEntity": [
        { "@type": "Question", "name": "How do I choose a base color?", "acceptedAnswer": { "@type": "Answer", "text": "Start with your project's purpose or brand logo color." } },
        { "@type": "Question", "name": "How many colors should a brand palette have?", "acceptedAnswer": { "@type": "Answer", "text": "3 to 5 core colors: primary, secondary, neutrals, accents." } },
        { "@type": "Question", "name": "How do I ensure my palette is accessible?", "acceptedAnswer": { "@type": "Answer", "text": "Use the Contrast Checker for WCAG AA compliance." } },
        { "@type": "Question", "name": "Monochromatic vs complementary?", "acceptedAnswer": { "@type": "Answer", "text": "Mono = subtle. Complementary = high-contrast for CTAs." } }
