---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MonetizationSlot from '../../components/MonetizationSlot.astro';
import ToolLayout from '../../components/ToolLayout.astro';
import { colors, getRelatedColors } from '../../data/colors';
import type { ColorData } from '../../data/colors';
import {
  generateTintsAndShades,
  generateComplementaryPalette,
  generateAnalogousPalette,
  generateTriadicPalette,
  generateSplitComplementaryPalette,
  generateTetradicPalette,
  rgbToHsl,
  getContrastRatio,
} from '../../utils/color';
import { toolLinks } from '../../utils/url';
import FAQ from '../../components/FAQ.astro';

export async function getStaticPaths() {
  return colors.map((color: ColorData) => ({
    params: { slug: color.slug },
    props: { color },
  }));
}

export interface Props {
  color: ColorData;
}

const { color } = Astro.props;

// Hex→Slug-Lookup für interne Verlinkung der Palette-Swatches
const colorByHex = new Map(colors.map(c => [c.hex.toLowerCase(), c.slug]));
const getColorSlug = (hexCode) => colorByHex.get(hexCode.toLowerCase());

// Cyan/Aqua and Fuchsia/Magenta are CSS-spec synonyms with identical hex values.
// To avoid duplicate content, set canonical URL to the primary page.
const canonicalSlug = (color.slug === 'aqua') ? 'cyan'
  : (color.slug === 'magenta') ? 'fuchsia'
  : color.slug;
const canonical = `https://color-helper.com/colors/${canonicalSlug}/`;

// Build description that includes synonym note for SEO clarity
const synonymNote = (color.slug === 'aqua') ? ' Aqua is a CSS synonym for cyan.'
  : (color.slug === 'magenta') ? ' Magenta is a CSS synonym for fuchsia.'
  : '';

const title = `${color.name} Color — HEX, RGB, HSL, Palettes & Contrast`;
const description = `${color.name} (${color.hex}): Complete color reference with HEX, RGB, HSL values, tints & shades, complementary, analogous, triadic, split-complementary, and tetradic palettes, WCAG contrast recommendations, and ready-to-use CSS code.${synonymNote}`;
const breadcrumbs = [
  { label: 'Colors', href: '/colors/' },
  { label: color.name },
];

// Color values
const hsl = rgbToHsl(color.r, color.g, color.b);
const hslStr = `${hsl.h}°, ${hsl.s}%, ${hsl.l}%`;

// Palettes
const tintsShades = generateTintsAndShades(color.hex, 9);
const complementary = generateComplementaryPalette(color.hex);
const analogous = generateAnalogousPalette(color.hex);
const triadic = generateTriadicPalette(color.hex);
const splitComplementary = generateSplitComplementaryPalette(color.hex);
const tetradic = generateTetradicPalette(color.hex);

// Related colors
const relatedColors = getRelatedColors(color);

// Contrast (using shared utils)
const contrastBlack = getContrastRatio('#000000', color.hex);
const contrastWhite = getContrastRatio('#ffffff', color.hex);

// Choose label background/text based on which has better contrast
const labelBg = contrastBlack > contrastWhite ? 'rgba(0,0,0,0.6)' : 'rgba(255,255,255,0.7)';
const labelFg = contrastBlack > contrastWhite ? '#ffffff' : '#000000';

// Accessibility Score (0-100): combines contrast scores + brightness range
// - Text on best-contrast (black or white) AA pass: 25 pts
// - Text on best-contrast AAA pass: 25 pts
// - Mid-luminance (versatile for backgrounds AND text): 25 pts
// - Luminance is not too close to pure black/white: 25 pts
const hslForScore = rgbToHsl(color.r, color.g, color.b);
const bestContrast = Math.max(contrastBlack, contrastWhite);
const aaPass = bestContrast >= 4.5;
const aaaPass = bestContrast >= 7;
const versatileLightness = hslForScore.l >= 20 && hslForScore.l <= 80; // not too dark/bright
const notExtreme = hslForScore.l >= 5 && hslForScore.l <= 95; // not pure black/white
let a11yScore = 0;
if (aaPass) a11yScore += 30;
if (aaaPass) a11yScore += 25;
if (versatileLightness) a11yScore += 25;
if (notExtreme) a11yScore += 20;
let a11yGrade = 'Poor';
let a11yGradeColor = '#ef4444';
if (a11yScore >= 85) { a11yGrade = 'Excellent'; a11yGradeColor = '#22c55e'; }
else if (a11yScore >= 70) { a11yGrade = 'Good'; a11yGradeColor = '#22c55e'; }
else if (a11yScore >= 50) { a11yGrade = 'Fair'; a11yGradeColor = '#eab308'; }
else if (a11yScore >= 25) { a11yGrade = 'Limited'; a11yGradeColor = '#f97316'; }

// Per-color OG-Image (generated by scripts/build-og-images.mjs)
const ogImage = `https://color-helper.com/og/colors/${color.slug}.webp`;

// JSON-LD Structured Data — konsolidiert in @graph
//
// Fünf verknüpfte Schema-Objekte (Google Rich-Snippet-fähig):
//   1. WebPage        — Container für die ganze Seite
//   2. DefinedTerm    — Der Farbname (z.B. "Midnight Blue") mit HEX/RGB/HSL
//   3. BreadcrumbList — Brösel-Pfad in Google-Suchergebnissen
//   4. FAQPage        — FAQ-Snippet (3 Fragen pro Color-Page)
//   5. HowTo          — HowTo-Rich-Snippet: "How to use #FF0000 in CSS"
//
// Konsolidiert in EINEM <script>-Block (vorher 5 separate) für bessere
// Validierung und weniger Render-Overhead.
const wikiLink = `https://en.wikipedia.org/wiki/Web_colors#${color.name.replace(/\s+/g, '_')}`;
const colorNameLink = `https://www.color-name.com/hex/${color.hex.replace('#', '').toLowerCase()}`;

const webPageNode = {
  "@type": "WebPage",
  "@id": canonical,
  "url": canonical,
  "name": title,
  "description": description,
  "inLanguage": "en",
  "isPartOf": {
    "@type": "WebSite",
    "name": "Color Helper",
    "url": "https://color-helper.com"
  },
  "primaryImageOfPage": {
    "@type": "ImageObject",
    "url": ogImage,
    "width": 1200,
    "height": 630
  },
  "mainEntity": { "@id": `${canonical}#term` },
  "about": { "@id": `${canonical}#term` }
};

const definedTermNode = {
  "@type": "DefinedTerm",
  "@id": `${canonical}#term`,
  "name": color.name,
  "alternateName": color.tags || [],
  "description": color.description,
  "inDefinedTermSet": {
    "@type": "DefinedTermSet",
    "name": "CSS Named Colors",
    "url": "https://www.w3.org/TR/css-color-4/#named-colors",
    "publisher": {
      "@type": "Organization",
      "name": "W3C",
      "url": "https://www.w3.org/"
    }
  },
  "termCode": color.hex,
  "identifier": color.hex,
  "sameAs": [
    wikiLink,
    colorNameLink,
    // Wikidata-Q-ID nur wenn verifiziert (siehe scripts/wikidata-verified.json).
    // Halluzinierte Q-IDs würden Google's Authority-Score verschlechtern.
    ...(color.slug === "white" ? ["https://www.wikidata.org/wiki/Q23444"] :
       color.slug === "red" ? ["https://www.wikidata.org/wiki/Q3142"] :
       color.slug === "blue" ? ["https://www.wikidata.org/wiki/Q1088"] :
       color.slug === "green" ? ["https://www.wikidata.org/wiki/Q3133"] :
       color.slug === "yellow" ? ["https://www.wikidata.org/wiki/Q943"] :
       [])
  ],
  "colorValue": {
    "@type": "PropertyValue",
    "name": "HEX",
    "value": color.hex.toUpperCase()
  },
  "additionalProperty": [
    {
      "@type": "PropertyValue",
      "name": "RGB",
      "value": `rgb(${color.r}, ${color.g}, ${color.b})`
    },
    {
      "@type": "PropertyValue",
      "name": "HSL",
      "value": `${hslForScore.h}°, ${hslForScore.s}%, ${hslForScore.l}%`
    },
    {
      "@type": "PropertyValue",
      "name": "CSS Category",
      "value": color.category
    }
  ]
};

const breadcrumbNode = {
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://color-helper.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Colors",
      "item": "https://color-helper.com/colors/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": color.name,
      "item": canonical
    }
  ]
};

// HowTo-Schema: "How to use {color.name} (#HEX) in CSS"
// HowTo-Rich-Snippet in Google SERPs (3-Step-Prozess).
const howToNode = {
  "@type": "HowTo",
  "name": `How to use ${color.name} (${color.hex.toUpperCase()}) in CSS`,
  "description": `Step-by-step guide to apply ${color.name} as a background, text color, or border in HTML and CSS.`,
  "totalTime": "PT2M",
  "tool": [
    { "@type": "HowToTool", "name": "CSS color property" },
    { "@type": "HowToTool", "name": "HTML element" }
  ],
  "step": [
    {
      "@type": "HowToStep",
      "position": 1,
      "name": "Copy the hex value",
      "text": `Copy the hex value ${color.hex.toUpperCase()} from the color values table above.`,
      "url": `${canonical}#values`
    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "Use it in a CSS rule",
      "text": `Add a CSS rule and set the background, color, or border property to ${color.hex.toUpperCase()}. Example: .my-element { background-color: ${color.hex.toLowerCase()}; }`,
      "url": `${canonical}#how-to`
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "Check accessibility (WCAG contrast)",
      "text": `Use the Color Helper contrast checker to verify that ${color.name} (${color.hex.toUpperCase()}) meets WCAG AA/AAA contrast ratios against your text and background colors.`,
      "url": "https://color-helper.com/contrast-checker/"
    }
  ]
};

// FAQPage-Schema: 3 Fragen pro Color-Page (FAQ-Component rendert mit skipJsonLd).
// Wir bauen es hier im @graph mit ein.
const faqPageNode = {
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `What color is ${color.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${color.name} is represented by the hex code ${color.hex} and has RGB values of rgb(${color.r}, ${color.g}, ${color.b}). It falls under the ${color.category} category.`
      }
    },
    {
      "@type": "Question",
      "name": `How to use ${color.name} in web design?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${color.name} works well for ${color.useCases.slice(0, 3).join(', ')}. ${color.description} Use it as a primary color, accent, or background depending on your design needs.`
      }
    },
    {
      "@type": "Question",
      "name": `What colors go with ${color.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Colors that pair well with ${color.name} include ${color.related.slice(0, 5).join(', ')}. For a complementary scheme, try ${complementary.colors[1]}. For an analogous scheme, use ${analogous.colors[0]} and ${analogous.colors[2]}. For a triadic scheme, combine with ${triadic.colors[1]} and ${triadic.colors[2]}.`
      }
    }
  ]
};

// Konsolidierter @graph (wird im Body gerendert)
const colorSchemaGraph = {
  "@context": "https://schema.org",
  "@graph": [webPageNode, definedTermNode, breadcrumbNode, howToNode, faqPageNode]
};

// ogImage wurde weiter oben deklariert (für primaryImageOfPage)
---

<BaseLayout {title} {description} {canonical} {breadcrumbs} {ogImage}>
  <ToolLayout {title} {description} {breadcrumbs}>
    <!-- Color Swatch -->
    <div class="color-hero">
      <div class="color-swatch" style={{ backgroundColor: color.hex }}>
        <span class="color-hex-label" style={{ background: labelBg, color: labelFg }}>{color.hex}</span>
      </div>
    </div>

    <!-- Color Values -->
    <section class="color-values">
      <div class="value-card">
        <span class="value-label">HEX</span>
        <code class="value-code">{color.hex}</code>
        <button class="copy-btn" data-copy-value={color.hex} title="Copy HEX value">Copy</button>
      </div>
      <div class="value-card">
        <span class="value-label">RGB</span>
        <code class="value-code">rgb({color.r}, {color.g}, {color.b})</code>
        <button class="copy-btn" data-copy-value={`rgb(${color.r}, ${color.g}, ${color.b})`} title="Copy RGB value">Copy</button>
      </div>
      <div class="value-card">
        <span class="value-label">HSL</span>
        <code class="value-code">{hslStr}</code>
        <button class="copy-btn" data-copy-value={hslStr} title="Copy HSL value">Copy</button>
      </div>
    </section>

    <!-- Tool Action Buttons -->
    <section class="tool-ctas">
      <h2>Use {color.name} in Your Projects</h2>
      <div class="tool-cta-grid">
        <a href={toolLinks.colorPicker(color.hex)} class="tool-cta-card">
          <span class="tool-cta-icon">🎨</span>
          <span class="tool-cta-label">Open in Color Picker</span>
        </a>
        <a href={toolLinks.paletteGenerator(color.hex)} class="tool-cta-card">
          <span class="tool-cta-icon">🌈</span>
          <span class="tool-cta-label">Generate Palette</span>
        </a>
        <a href={toolLinks.contrastChecker(color.hex, 'ffffff')} class="tool-cta-card">
          <span class="tool-cta-icon">👁️</span>
          <span class="tool-cta-label">Check Contrast</span>
        </a>
        <a href={toolLinks.colorConverter(color.hex)} class="tool-cta-card">
          <span class="tool-cta-icon">🔄</span>
          <span class="tool-cta-label">Convert Color</span>
        </a>
        <a href={toolLinks.gradientGenerator(color.hex, 'ffffff')} class="tool-cta-card">
          <span class="tool-cta-icon">🌊</span>
          <span class="tool-cta-label">Use in Gradient</span>
        </a>
      </div>
    </section>

    <!-- Description -->
    <!-- Ad: Tool-Bottom — zwischen Tool-UI und SEO-Text -->
    <MonetizationSlot position="tool-bottom" adFormat="horizontal" />

    <section class="seo-content">
      <h2>About {color.name} Color</h2>
      <p>{color.description}</p>
    </section>

    <!-- Use Cases -->
    <section class="use-cases">
      <h2>Use Cases for {color.name}</h2>
      <div class="use-cases-grid">
        {color.useCases.map(useCase => (
          <span class="use-case-tag">{useCase}</span>
        ))}
      </div>
    </section>

    <!-- Tints & Shades -->
    <section class="palette-section">
      <h2>Shades &amp; Tints of {color.name}</h2>
      <div class="palette-swatches">
        {tintsShades.colors.map(c => (
          <div class="palette-swatch" title={c} style={{ backgroundColor: c }}>
            <span class="palette-swatch-label">{c}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Complementary Palette -->
    <section class="palette-section">
      <h2>Complementary Color</h2>
      <div class="palette-swatches palette-compact">
        {complementary.colors.map(c => {
          const slug = getColorSlug(c);
          const style = `background-color: ${c}`;
          return slug && slug !== color.slug
            ? <a href={`/colors/${slug}/`} class="palette-swatch palette-swatch-link" title={c} style={style}><span class="palette-swatch-label">{c}</span></a>
            : <div class="palette-swatch" title={c} style={style}><span class="palette-swatch-label">{c}</span></div>;
        })}
      </div>
    </section>

    <!-- Analogous Palette -->
    <section class="palette-section">
      <h2>Analogous Colors</h2>
      <div class="palette-swatches">
        {analogous.colors.map(c => {
          const slug = getColorSlug(c);
          const style = `background-color: ${c}`;
          return slug && slug !== color.slug
            ? <a href={`/colors/${slug}/`} class="palette-swatch palette-swatch-link" title={c} style={style}><span class="palette-swatch-label">{c}</span></a>
            : <div class="palette-swatch" title={c} style={style}><span class="palette-swatch-label">{c}</span></div>;
        })}
      </div>
    </section>

    <!-- Triadic Palette -->
    <section class="palette-section">
      <h2>Triadic Colors</h2>
      <div class="palette-swatches">
        {triadic.colors.map(c => {
          const slug = getColorSlug(c);
          const style = `background-color: ${c}`;
          return slug && slug !== color.slug
            ? <a href={`/colors/${slug}/`} class="palette-swatch palette-swatch-link" title={c} style={style}><span class="palette-swatch-label">{c}</span></a>
            : <div class="palette-swatch" title={c} style={style}><span class="palette-swatch-label">{c}</span></div>;
        })}
      </div>
    </section>

    <!-- Split Complementary Palette -->
    <section class="palette-section">
      <h2>Split Complementary</h2>
      <div class="palette-swatches">
        {splitComplementary.colors.map(c => {
          const slug = getColorSlug(c);
          const style = `background-color: ${c}`;
          return slug && slug !== color.slug
            ? <a href={`/colors/${slug}/`} class="palette-swatch palette-swatch-link" title={c} style={style}><span class="palette-swatch-label">{c}</span></a>
            : <div class="palette-swatch" title={c} style={style}><span class="palette-swatch-label">{c}</span></div>;
        })}
      </div>
    </section>

    <!-- Tetradic Palette -->
    <section class="palette-section">
      <h2>Tetradic Colors</h2>
      <div class="palette-swatches">
        {tetradic.colors.map(c => {
          const slug = getColorSlug(c);
          const style = `background-color: ${c}`;
          return slug && slug !== color.slug
            ? <a href={`/colors/${slug}/`} class="palette-swatch palette-swatch-link" title={c} style={style}><span class="palette-swatch-label">{c}</span></a>
            : <div class="palette-swatch" title={c} style={style}><span class="palette-swatch-label">{c}</span></div>;
        })}
      </div>
    </section>

    <!-- CSS Snippet -->
    <section class="css-snippet-section">
      <h2>CSS Code</h2>
      <pre class="css-snippet"><code>.{color.slug}-color &#123;
  color: {color.hex};
  background-color: {color.hex};
&#125;

/* As a CSS custom property */
:root &#123;
  --color-{color.slug}: {color.hex};
&#125;</code></pre>
    </section>

    <!-- Accessibility Score -->
    <section class="a11y-score-section">
      <h2>Accessibility Score</h2>
      <div class="a11y-score-card">
        <div class="a11y-score-circle" style={`background: conic-gradient(${a11yGradeColor} ${a11yScore * 3.6}deg, var(--color-bg-alt) 0deg);`}>
          <div class="a11y-score-inner">
            <span class="a11y-score-number" style={`color: ${a11yGradeColor};`}>{a11yScore}</span>
            <span class="a11y-score-of">/ 100</span>
          </div>
        </div>
        <div class="a11y-score-details">
          <div class="a11y-grade-row">
            <span class="a11y-grade-label">Rating:</span>
            <span class="a11y-grade-value" style={`color: ${a11yGradeColor};`}>{a11yGrade}</span>
          </div>
          <div class="a11y-breakdown">
            <div class={`a11y-check ${aaPass ? 'pass' : 'fail'}`}>
              <span class="a11y-check-icon">{aaPass ? '✓' : '✗'}</span>
              <span>AA contrast on best text color (30 pts)</span>
            </div>
            <div class={`a11y-check ${aaaPass ? 'pass' : 'fail'}`}>
              <span class="a11y-check-icon">{aaaPass ? '✓' : '✗'}</span>
              <span>AAA contrast on best text color (25 pts)</span>
            </div>
            <div class={`a11y-check ${versatileLightness ? 'pass' : 'fail'}`}>
              <span class="a11y-check-icon">{versatileLightness ? '✓' : '✗'}</span>
              <span>Versatile lightness for backgrounds & text (25 pts)</span>
            </div>
            <div class={`a11y-check ${notExtreme ? 'pass' : 'fail'}`}>
              <span class="a11y-check-icon">{notExtreme ? '✓' : '✗'}</span>
              <span>Not extreme black/white (20 pts)</span>
            </div>
          </div>
        </div>
      </div>
      <p class="a11y-explainer">A combined score based on WCAG contrast compliance, lightness versatility, and usable range. Higher scores mean the color works well in more design contexts.</p>
    </section>

    <!-- Contrast Recommendations -->
    <section class="contrast-section">
      <h2>Contrast Recommendations</h2>
      <div class="contrast-cards">
        <div class="contrast-card contrast-card-black">
          <div class="contrast-preview" style={{ backgroundColor: color.hex, color: '#000000' }}>
            Black text on {color.name}
          </div>
          <div class="contrast-info">
            <span class="contrast-ratio">Ratio: {contrastBlack}:1</span>
            <span class={`contrast-pass ${contrastBlack >= 4.5 ? 'pass' : 'fail'}`}>
              {contrastBlack >= 4.5 ? '✓ Passes AA' : '✗ Fails AA'}
            </span>
            <span class={`contrast-pass ${contrastBlack >= 7 ? 'pass' : 'fail'}`}>
              {contrastBlack >= 7 ? '✓ Passes AAA' : '✗ Fails AAA'}
            </span>
          </div>
        </div>
        <div class="contrast-card contrast-card-white">
          <div class="contrast-preview" style={{ backgroundColor: color.hex, color: '#ffffff' }}>
            White text on {color.name}
          </div>
          <div class="contrast-info">
            <span class="contrast-ratio">Ratio: {contrastWhite}:1</span>
            <span class={`contrast-pass ${contrastWhite >= 4.5 ? 'pass' : 'fail'}`}>
              {contrastWhite >= 4.5 ? '✓ Passes AA' : '✗ Fails AA'}
            </span>
            <span class={`contrast-pass ${contrastWhite >= 7 ? 'pass' : 'fail'}`}>
              {contrastWhite >= 7 ? '✓ Passes AAA' : '✗ Fails AAA'}
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- Related Colors -->
    <section class="related-colors">
      <h2>Related Colors</h2>
      <div class="related-colors-grid">
        {relatedColors.map(rel => (
          <a href={`/colors/${rel.slug}/`} class="related-color-card">
            <div class="related-color-swatch" style={{ backgroundColor: rel.hex }}></div>
            <span class="related-color-name">{rel.name}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Related Tools -->
    <!-- Ad: In-Content — nach SEO-Text, vor Related-Tools -->
    <MonetizationSlot position="in-content" adFormat="horizontal" />

    <section class="related-tools">
      <h2>Related Tools</h2>
      <ul>
        <li><a href="/color-picker/">Color Picker</a> — Pick and save colors interactively</li>
        <li><a href="/color-palette-generator/">Palette Generator</a> — Create harmonious color schemes</li>
        <li><a href="/contrast-checker/">Contrast Checker</a> — Check WCAG accessibility ratios</li>
        <li><a href="/color-converter/">Color Converter</a> — Convert between HEX, RGB, and HSL</li>
        <li><a href="/gradient-generator/">Gradient Generator</a> — Create CSS gradients</li>
      </ul>
    </section>

    <FAQ
      skipJsonLd
      items={[
        {
          question: `What color is ${color.name}?`,
          answer: `${color.name} is represented by the hex code ${color.hex} and has RGB values of rgb(${color.r}, ${color.g}, ${color.b}). It falls under the ${color.category} category.`
        },
        {
          question: `How to use ${color.name} in web design?`,
          answer: `${color.name} works well for ${color.useCases.slice(0, 3).join(', ')}. ${color.description} Use it as a primary color, accent, or background depending on your design needs.`
        },
        {
          question: `What colors go with ${color.name}?`,
          answer: `Colors that pair well with ${color.name} include ${color.related.slice(0, 5).join(', ')}. For a complementary scheme, try ${complementary.colors[1]}. For an analogous scheme, use ${analogous.colors[0]} and ${analogous.colors[2]}. For a triadic scheme, combine with ${triadic.colors[1]} and ${triadic.colors[2]}.`
        }
      ]}
    />
  </ToolLayout>

  <script>
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        const value = btn.getAttribute('data-copy-value');
        if (!value) return;
        try {
          await navigator.clipboard.writeText(value);
        } catch {
          const ta = document.createElement('textarea');
          ta.value = value;
          ta.style.position = 'fixed';
          ta.style.opacity = '0';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
        }
        const orig = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = orig; }, 1500);
      });
    });
  </script>

