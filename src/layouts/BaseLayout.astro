---
import '../styles/global.css';
import '../styles/print.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import BackToTop from '../components/BackToTop.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  breadcrumbs?: { label: string; href?: string }[];
  noIndex?: boolean;
  isTool?: boolean;
}

const { title, description, canonical, ogImage, breadcrumbs, noIndex, isTool } = Astro.props;
const siteUrl = 'https://color-helper.com';
const pageUrl = canonical || siteUrl;
// Default-OG-Image: 1200x630, brand-gradient.
// Pro Page kann eine eigene ogImage via Prop überschrieben werden.
const defaultOgImage = `${siteUrl}/og/default.png`;
const ogImageUrl = ogImage || defaultOgImage;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="WyuJk7RUyxCj0kp7Xy7DwAyW8q5UZWjCmK3Gkhw-uso" />
    <title>{title.endsWith('Color Helper') ? title : `${title} | Color Helper`}</title>
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={pageUrl} />

    <!-- OpenGraph -->
    <meta property="og:type" content={isTool ? 'website' : 'website'} />
    <meta property="og:title" content={`${title} | Color Helper`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="Color Helper" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:image:type" content="image/png" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Color Helper`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Robots -->
    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://pagead2.googlesyndication.com" />

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- Google AdSense Auto Ads -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9094916118868532"
            crossorigin="anonymous"></script>

    <!-- Theme initialization (before render, prevents flash) -->
    <script>
      (() => {
        try {
          const stored = localStorage.getItem('ch-theme') || 'system';
          let theme = stored;
          if (theme === 'system') {
            theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          document.documentElement.setAttribute('data-theme', theme);
        } catch {}
      })();
    </script>

    <!-- JSON-LD: WebSite schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Color Helper",
      "url": siteUrl,
      "description": "Free color tools for designers, developers and creators.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": `${siteUrl}/?q={search_term_string}`
        },
        "query-input": "required name=search_term_string"
      }
    })}></script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <Header />
    <main id="main-content">
      {breadcrumbs && breadcrumbs.length > 0 && (
        <div class="container" style="padding-top: 1rem; padding-bottom: 0;">
          <Breadcrumbs items={breadcrumbs} />
        </div>
      )}
      <slot />
    </main>
    <Footer />
    <BackToTop />
  </body>
</html>

<style is:global>
  /* Additional layout styles */
  main {
    min-height: calc(100vh - var(--header-height) - 280px);
  }
</style>
