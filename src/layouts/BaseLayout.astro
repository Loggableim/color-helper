---
import '../styles/global.css';
import '../styles/print.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import BackToTop from '../components/BackToTop.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  breadcrumbs?: { label: string; href?: string }[];
  noIndex?: boolean;
  isTool?: boolean;
}

const { title, description, canonical, ogImage, breadcrumbs, noIndex, isTool } = Astro.props;
const siteUrl = 'https://color-helper.com';
const pageUrl = canonical || siteUrl;
// Default-OG-Image: 1200x630, brand-gradient.
// Pro Page kann eine eigene ogImage via Prop überschrieben werden.
const defaultOgImage = `${siteUrl}/og/default.webp`;
const ogImageUrl = ogImage || defaultOgImage;

// SEO-Constraints:
//   Title: max 60 Zeichen (Google SERPs schneiden ab ~60 ab, pi mal Daumen).
//   Description: max 155 Zeichen (Google snippet cutoff ~155-160).
//   Wir kürzen intelligent mit Ellipsis "…", nicht mit hard truncate.
const MAX_TITLE = 60;
const MAX_DESCRIPTION = 155;

function buildFullTitle(t: string): string {
  if (t.endsWith('Color Helper')) return t;
  return `${t} | Color Helper`;
}

function truncate(s: string, max: number): string {
  if (s.length <= max) return s;
  // Cut at last word boundary within max-1 chars
  const cut = s.slice(0, max - 1);
  const lastSpace = cut.lastIndexOf(' ');
  return (lastSpace > max * 0.6 ? cut.slice(0, lastSpace) : cut).trim() + '…';
}

const fullTitle = buildFullTitle(title);
const finalTitle = truncate(fullTitle, MAX_TITLE);
const finalDescription = truncate(description, MAX_DESCRIPTION);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="WyuJk7RUyxCj0kp7Xy7DwAyW8q5UZWjCmK3Gkhw-uso" />
    <title>{finalTitle}</title>
    <meta name="description" content={finalDescription} />

    <!-- Canonical -->
    <link rel="canonical" href={pageUrl} />

    <!-- OpenGraph -->
    <meta property="og:type" content={isTool ? 'website' : 'website'} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="Color Helper" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:image:type" content="image/webp" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={finalDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Robots -->
    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Self-hosted Fonts (Inter + JetBrains Mono) — kein externer Google-Fonts-Request mehr -->
    <link rel="preload" href="/fonts/fonts.css" as="style" />
    <link rel="stylesheet" href="/fonts/fonts.css" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="/fonts/fonts.css" /></noscript>
    <link rel="preload" href="/fonts/Inter-400.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/JetBrainsMono-500.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preconnect" href="https://pagead2.googlesyndication.com" />

    <!-- Google AdSense Auto Ads — deferred bis erste User-Interaktion (klicken/scrollen)
         Blockiert nicht LCP/cls, da das Script erst nach User-Action lädt.
         (adsbygoogle = window.adsbygoogle || []).push({}) in MonetizationSlot
         funktioniert auch ohne dieses Script — die Queue wird geleert sobald
         adsbygoogle.js geladen ist. -->
    <script is:inline>
      (function() {
        var loaded = false;
        function loadAdSense() {
          if (loaded) return;
          loaded = true;
          var s = document.createElement('script');
          s.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9094916118868532';
          s.crossOrigin = 'anonymous';
          s.async = true;
          document.head.appendChild(s);
          // Remove listeners after first interaction
          document.removeEventListener('scroll', loadAdSense);
          document.removeEventListener('click', loadAdSense);
          document.removeEventListener('touchstart', loadAdSense);
        }
        document.addEventListener('scroll', loadAdSense, { once: true, passive: true });
        document.addEventListener('click', loadAdSense, { once: true });
        document.addEventListener('touchstart', loadAdSense, { once: true, passive: true });
        // Fallback: load after 8s even without interaction
        setTimeout(loadAdSense, 8000);
      })();
    </script>

    <!-- Theme initialization (before render, prevents flash) -->
    <script>
      (() => {
        try {
          const stored = localStorage.getItem('ch-theme') || 'system';
          let theme = stored;
          if (theme === 'system') {
            theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          document.documentElement.setAttribute('data-theme', theme);
        } catch {}
      })();
    </script>

    <!-- JSON-LD: WebSite schema with Sitelinks Search Box -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Color Helper",
      "alternateName": "Color Tools",
      "url": siteUrl,
      "description": "Free color tools for designers, developers and creators.",
      "inLanguage": "en",
      "publisher": {
        "@type": "Organization",
        "name": "Color Helper",
        "url": siteUrl,
        "logo": {
          "@type": "ImageObject",
          "url": `${siteUrl}/favicon.svg`,
          "width": 32,
          "height": 32
        }
      },
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": `${siteUrl}/colors/?q={search_term_string}`
        },
        "query-input": "required name=search_term_string"
      }
    })}></script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <Header />
    <main id="main-content">
      {breadcrumbs && breadcrumbs.length > 0 && (
        <div class="container" style="padding-top: 1rem; padding-bottom: 0;">
          <Breadcrumbs items={breadcrumbs} />
        </div>
      )}
      <slot />
    </main>
    <Footer />
    <BackToTop />
  </body>
</html>

<style is:global>
  /* Additional layout styles */
  main {
    min-height: calc(100vh - var(--header-height) - 280px);
  }
</style>
