---
const toolLinks = [
  { href: '/color-picker/', label: 'Color Picker' },
  { href: '/generate/color-wheel/', label: 'Color Wheel' },
  { href: '/generate/color-scale/', label: 'Color Scale' },
  { href: '/image-color-picker/', label: 'Image Color Picker' },
  { href: '/color-converter/', label: 'Color Converter' },
  { href: '/hex-to-rgb/', label: 'HEX to RGB' },
  { href: '/rgb-to-hex/', label: 'RGB to HEX' },
  { href: '/color-palette-generator/', label: 'Palette Generator' },
  { href: '/gradient-generator/', label: 'Gradient Generator' },
  { href: '/contrast-checker/', label: 'Contrast Checker' },
  { href: '/preview/', label: 'Palette Preview' },
  { href: '/export/', label: 'Export Center' },
  { href: '/compare/', label: 'Color Comparison' },
  { href: '/color-mixer/', label: 'Color Mixer' },
];

const resourceLinks = [
  { href: '/gallery/', label: 'Palette Gallery' },
  { href: '/palettes/', label: 'My Palettes' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
];

const legalLinks = [
  { href: '/privacy/', label: 'Privacy Policy' },
  { href: '/terms/', label: 'Terms of Use' },
];
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <svg width="32" height="32" viewBox="0 0 36 36" fill="none" aria-hidden="true">
            <rect x="2" y="2" width="32" height="32" rx="8" fill="url(#logoGrad)"/>
            <circle cx="18" cy="18" r="8" fill="white" fill-opacity="0.2"/>
            <circle cx="18" cy="14" r="3" fill="white"/>
            <defs>
              <linearGradient id="logoGrad" x1="0" y1="0" x2="36" y2="36" gradientUnits="userSpaceOnUse">
                <stop stop-color="var(--color-primary)"/>
                <stop offset="1" stop-color="var(--color-secondary)"/>
              </linearGradient>
            </defs>
          </svg>
          <span>Color Helper</span>
        </a>
        <p class="footer-tagline">
          Free color tools for designers, developers and creators.
        </p>
        <div class="footer-disclaimer-card">
          <p class="footer-disclaimer">
            Color Helper is an independent color utility website. It is not affiliated with any former Color Savvy products or companies.
          </p>
        </div>
      </div>

      <!-- Tools -->
      <div class="footer-col">
        <h4 class="footer-heading">Tools</h4>
        <ul class="footer-list">
          {toolLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div class="footer-col">
        <h4 class="footer-heading">Resources</h4>
        <ul class="footer-list">
          {resourceLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div class="footer-col">
        <h4 class="footer-heading">Legal</h4>
        <ul class="footer-list">
          {legalLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} Color Helper. All rights reserved.</p>
      <p class="footer-meta">
        <a href="#" data-action="open-consent">Cookie settings</a> ·
        <a href="/privacy/">Privacy</a> ·
        <a href="/terms/">Terms</a>
      </p>
    </div>
  </div>
</footer>

<script>
  // Cookie-Settings Button: öffnet ein simples Consent-Banner mit Grant/Deny
  (() => {
    const STORAGE_KEY = 'ch-consent';

    function readConsent(): { ads: boolean; ts: number } | null {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return null;
        return JSON.parse(raw);
      } catch {
        return null;
      }
    }

    function writeConsent(ads: boolean) {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify({ ads, ts: Date.now() }));
      } catch {
        /* ignore */
      }
    }

    function ensureBanner(): HTMLDivElement {
      let banner = document.getElementById('ch-consent-banner') as HTMLDivElement | null;
      if (banner) return banner;
      banner = document.createElement('div');
      banner.id = 'ch-consent-banner';
      banner.setAttribute('role', 'dialog');
      banner.setAttribute('aria-label', 'Cookie settings');
      banner.innerHTML = `
        <div class="ch-consent-inner">
          <div class="ch-consent-text">
            <strong>Cookie settings</strong>
            <p>Color Helper uses Google AdSense to display ads on tool pages. AdSense may set cookies to serve and cap ads. Your tool inputs (colors, images) always stay in your browser.</p>
          </div>
          <div class="ch-consent-actions">
            <button type="button" data-action="ch-consent-deny" class="ch-btn ch-btn-secondary">Deny</button>
            <button type="button" data-action="ch-consent-grant" class="ch-btn ch-btn-primary">Allow ads</button>
          </div>
        </div>
      `;
      document.body.appendChild(banner);

      // Apply styles (inline so we don't depend on global CSS)
      const style = document.createElement('style');
      style.textContent = `
        #ch-consent-banner { position: fixed; bottom: 1rem; left: 1rem; right: 1rem; max-width: 540px; margin: 0 auto; background: var(--color-bg-card, #fff); border: 1px solid var(--color-border, #e5e7eb); border-radius: 12px; padding: 1rem 1.25rem; box-shadow: 0 10px 30px rgba(0,0,0,.18); z-index: 10000; font-family: inherit; }
        .ch-consent-inner { display: flex; flex-direction: column; gap: .75rem; }
        .ch-consent-text strong { display: block; font-size: .95rem; margin-bottom: .25rem; }
        .ch-consent-text p { margin: 0; font-size: .8125rem; line-height: 1.5; color: var(--color-text-secondary, #64748b); }
        .ch-consent-actions { display: flex; gap: .5rem; justify-content: flex-end; }
        .ch-btn { font-size: .8125rem; font-weight: 600; padding: .5rem 1rem; border-radius: 8px; cursor: pointer; border: 1px solid var(--color-border, #e5e7eb); background: var(--color-bg-card, #fff); color: var(--color-text-primary); }
        .ch-btn-primary { background: var(--color-primary, #7C3AED); color: #fff; border-color: var(--color-primary, #7C3AED); }
        :global([data-theme="dark"]) #ch-consent-banner { background: #1f2937; border-color: #374151; }
      `;
      document.head.appendChild(style);

      banner.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const action = target.getAttribute('data-action');
        if (action === 'ch-consent-grant') {
          writeConsent(true);
          banner!.remove();
          // AdSense re-evaluates on next page interaction; reload is the simplest UX.
          window.location.reload();
        } else if (action === 'ch-consent-deny') {
          writeConsent(false);
          // Mark all slots as no_consent immediately
          document.querySelectorAll<HTMLElement>('.monetization-slot').forEach((s) => s.setAttribute('data-ad-state', 'no_consent'));
          banner!.remove();
        }
      });
      return banner;
    }

    function openBanner() {
      const banner = ensureBanner();
      banner.style.display = 'block';
    }

    // Wire up any element with data-action="open-consent" (footer link, privacy page link)
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.matches('[data-action="open-consent"]') || target.closest('[data-action="open-consent"]')) {
        e.preventDefault();
        openBanner();
      }
    });

    // First-time visitors with no decision yet → show banner automatically after 4s
    if (readConsent() === null) {
      setTimeout(openBanner, 4000);
    }
  })();
</script>

<style is:global>
  .site-footer {
    background: var(--color-bg-alt);
    border-top: none;
    padding: 4.5rem 0 0;
    margin-top: 5rem;
    position: relative;
  }

  .site-footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border), transparent);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.8fr 1.2fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
  }

  /* ---- Brand column ---- */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-text);
    text-decoration: none;
  }

  .footer-tagline {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    line-height: 1.6;
    max-width: 320px;
  }

  .footer-disclaimer-card {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(226, 232, 240, 0.6);
    border-radius: var(--radius-md);
    padding: 0.875rem 1rem;
    box-shadow: var(--shadow-xs);
  }

  .footer-disclaimer {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* ---- Column headings ---- */
  .footer-heading {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .footer-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-list a {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s var(--ease-out-expo);
    display: inline-block;
  }

  .footer-list a:hover {
    color: var(--color-primary);
  }

  /* ---- Bottom bar ---- */
  .footer-bottom {
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-border);
    text-align: center;
    position: relative;
  }

  .footer-bottom::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-primary-lighter), transparent);
    opacity: 0.4;
  }

  .footer-bottom p {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-tagline {
      max-width: 100%;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
      gap: 2rem;
    }
  }
</style>
