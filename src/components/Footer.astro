---
const toolLinks = [
  { href: '/color-picker/', label: 'Color Picker' },
  { href: '/image-color-picker/', label: 'Image Color Picker' },
  { href: '/hex-to-rgb/', label: 'HEX to RGB' },
  { href: '/rgb-to-hex/', label: 'RGB to HEX' },
  { href: '/color-palette-generator/', label: 'Palette Generator' },
  { href: '/contrast-checker/', label: 'Contrast Checker' },
  { href: '/gradient-generator/', label: 'Gradient Generator' },
  { href: '/paint-color-matching/', label: 'Paint Color Matching' },
];

const resourceLinks = [
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
  { href: '/privacy/', label: 'Privacy' },
];

const legalLinks = [
  { href: '/privacy/', label: 'Privacy Policy' },
  { href: '/about/', label: 'Terms of Use' },
];
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <svg width="32" height="32" viewBox="0 0 36 36" fill="none" aria-hidden="true">
            <rect x="2" y="2" width="32" height="32" rx="8" fill="url(#logoGrad)"/>
            <circle cx="18" cy="18" r="8" fill="white" fill-opacity="0.2"/>
            <circle cx="18" cy="14" r="3" fill="white"/>
            <defs>
              <linearGradient id="logoGrad" x1="0" y1="0" x2="36" y2="36" gradientUnits="userSpaceOnUse">
                <stop stop-color="var(--color-primary)"/>
                <stop offset="1" stop-color="var(--color-secondary)"/>
              </linearGradient>
            </defs>
          </svg>
          <span>Color Helper</span>
        </a>
        <p class="footer-tagline">
          Free color tools for designers, developers and creators.
        </p>
        <div class="footer-disclaimer-card">
          <p class="footer-disclaimer">
            Color Helper is an independent color utility website. It is not affiliated with any former Color Savvy products or companies.
          </p>
        </div>
      </div>

      <!-- Tools -->
      <div class="footer-col">
        <h4 class="footer-heading">Tools</h4>
        <ul class="footer-list">
          {toolLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div class="footer-col">
        <h4 class="footer-heading">Resources</h4>
        <ul class="footer-list">
          {resourceLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div class="footer-col">
        <h4 class="footer-heading">Legal</h4>
        <ul class="footer-list">
          {legalLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} Color Helper. All rights reserved.</p>
    </div>
  </div>
</footer>

<style is:global>
  .site-footer {
    background: var(--color-bg-alt);
    border-top: none;
    padding: 4.5rem 0 0;
    margin-top: 5rem;
    position: relative;
  }

  .site-footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border), transparent);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.8fr 1.2fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
  }

  /* ---- Brand column ---- */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-text);
    text-decoration: none;
  }

  .footer-tagline {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    line-height: 1.6;
    max-width: 320px;
  }

  .footer-disclaimer-card {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(226, 232, 240, 0.6);
    border-radius: var(--radius-md);
    padding: 0.875rem 1rem;
    box-shadow: var(--shadow-xs);
  }

  .footer-disclaimer {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* ---- Column headings ---- */
  .footer-heading {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .footer-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-list a {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s var(--ease-out-expo);
    display: inline-block;
  }

  .footer-list a:hover {
    color: var(--color-primary);
  }

  /* ---- Bottom bar ---- */
  .footer-bottom {
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-border);
    text-align: center;
    position: relative;
  }

  .footer-bottom::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-primary-lighter), transparent);
    opacity: 0.4;
  }

  .footer-bottom p {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-tagline {
      max-width: 100%;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
      gap: 2rem;
    }
  }
</style>
