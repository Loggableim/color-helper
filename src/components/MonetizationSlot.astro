---
/**
 * MonetizationSlot.astro
 * ────────────────────────────────────────────────────────────
 * AdSense-Display-Ad-Slot. Wird von der Seite per <MonetizationSlot position="..." /> eingebunden.
 *
 * Echte Ad-Ins (display ads). AdSense Auto-Ads laufen separat im <head>.
 *
 * Wichtig für AdSense-Compliance:
 *   - Mindestabstand 50px vom Tool / Eingabefeldern (AdSense-Policy)
 *   - Nicht im ersten Viewport direkt unter H1 (User Experience)
 *   - Nicht überlappend mit <main>-Padding
 *   - Inhaltliche Trennung vom Haupt-Content (deutliche <ins>-Trennung)
 *
 * Performance:
 *   - Lazy-Load via IntersectionObserver — erst wenn 200px im Viewport
 *   - (adsbygoogle = window.adsbygoogle || []).push({}) wird EINMAL pro Slot gefeuert
 */
export interface Props {
  position?: 'tool-bottom' | 'in-content' | 'sidebar-top' | 'sidebar-bottom' | 'footer';
  adSlot?: string;          // AdSense ad-slot ID
  adFormat?: 'auto' | 'rectangle' | 'horizontal' | 'vertical';
  className?: string;
}

const {
  position = 'in-content',
  adSlot = '',             // leer lassen bis AdSense echte Slots ausspuckt
  adFormat = 'auto',
  className = '',
} = Astro.props;

// Format-spezifische Dimensionen (für AdSense-Compliance)
const formatStyles: Record<string, string> = {
  auto: 'display:block; min-height: 100px;',
  rectangle: 'display:inline-block; width:300px; height:250px;',
  horizontal: 'display:inline-block; width:728px; height:90px; max-width:100%;',
  vertical: 'display:inline-block; width:160px; height:600px;',
};
const style = formatStyles[adFormat] || formatStyles.auto;
---

<div
  class={`monetization-slot monetization-slot--${position} ${className}`}
  data-monetization-position={position}
  aria-label="Advertisement"
  role="complementary"
>
  <ins
    class="adsbygoogle"
    style={style}
    data-ad-client="ca-pub-9094916118868532"
    data-ad-slot={adSlot}
    data-ad-format={adFormat}
    data-full-width-responsive="true"
  ></ins>
  <p class="monetization-slot__label">— Advertisement —</p>
</div>

<script>
  // Lazy-init: AdSense-Ins erst füllen, wenn Slot im Viewport sichtbar wird
  if (typeof window !== 'undefined') {
    const initSlots = () => {
      const slots = document.querySelectorAll<HTMLElement>('.monetization-slot:not([data-initialized])');
      if (!slots.length) return;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              el.setAttribute('data-initialized', 'true');
              try {
                ((window as any).adsbygoogle = (window as any).adsbygoogle || []).push({});
              } catch (e) {
                console.warn('[MonetizationSlot] AdSense push failed', e);
              }
              observer.unobserve(el);
            }
          });
        },
        { rootMargin: '200px 0px' }
      );

      slots.forEach((s) => observer.observe(s));
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSlots);
    } else {
      initSlots();
    }
  }
</script>

<style>
  .monetization-slot {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin: 2rem auto;
    padding: 1.25rem 1rem;
    background: var(--color-bg-alt, #f9fafb);
    border: 1px dashed var(--color-border, #e5e7eb);
    border-radius: 0.75rem;
    max-width: 100%;
    min-height: 120px;
  }

  .monetization-slot--tool-bottom {
    margin-top: 2.5rem;
    margin-bottom: 2.5rem;
  }

  .monetization-slot--in-content {
    margin: 3rem auto;
    max-width: 728px;
  }

  .monetization-slot--footer {
    margin-top: 1rem;
    margin-bottom: 1rem;
  }

  .monetization-slot__label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted, #9ca3af);
    margin: 0.75rem 0 0;
    font-weight: 500;
  }

  /* Dark-Mode-Anpassung */
  :global([data-theme="dark"]) .monetization-slot {
    background: var(--color-bg-alt, #1f2937);
    border-color: var(--color-border, #374151);
  }

  /* Mobile: Stack sicher untereinander, kein Overflow */
  @media (max-width: 768px) {
    .monetization-slot {
      margin: 1.5rem 0;
      padding: 1rem 0.5rem;
    }
    .monetization-slot--in-content {
      max-width: 100%;
    }
  }
</style>
