/* Cloudflare Pages: public/_headers
   Site-wide HTTP headers — Security & Caching.
   Reihenfolge: spezifischste zuerst (CF-Pages wendet sie in File-Order an,
   spezifischere Pfade müssen vor generischeren kommen).
   Docs: https://developers.cloudflare.com/pages/configuration/headers/

   Hinweis: '/' matched nur die exakte Root. '/foo' matched '/foo' und
   '/foo/'. '/*' matched alles inklusive Sub-Paths.
*/

/* Spezifische Pfade zuerst (mehrere einzelne für korrekte Cache-Zeiten) */
/robots.txt
  Cache-Control: public, max-age=3600
/sitemap*.xml
  Cache-Control: public, max-age=3600
/a28f2699c1dd4b92bf5de35fa41cc70b.txt
  Cache-Control: public, max-age=86400
/og/*
  Cache-Control: public, max-age=31536000, immutable
/_assets/*
  Cache-Control: public, max-age=31536000, immutable

/* Default: alle HTML-Seiten — Security-Header + kurze Cache-Zeit.
   '/*' matcht /color-picker/, /colors/red/, /404, etc. — alles ab Root.
   Da die spezifischen Regeln oben bereits Cache-Control gesetzt haben,
   werden sie durch nachfolgende Regeln nicht überschrieben (CF joinet). */
/
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-XSS-Protection: 0
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://pagead2.googlesyndication.com https://www.googletagservices.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https:; frame-src 'self' https://pagead2.googlesyndication.com https://googleads.g.doubleclick.net; frame-ancestors 'self'; base-uri 'self'; form-action 'self'
  Cache-Control: public, max-age=0, must-revalidate

